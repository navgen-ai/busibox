# =============================================================================
# Rackspace Spot Terraform Variables
# =============================================================================
# Copy to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to git!

# Rackspace Spot API token (from https://spot.rackspace.com -> API Access)
rackspace_spot_token = "YOUR_TOKEN_HERE"

# Cloudspace configuration
cloudspace_name = "sonnenreich-dev"
region          = "us-east-iad-1"

# Base node pool (always running)
base_server_class = "mh.vs1.xlarge-iad"  # 8 CPU, 60GB RAM
base_bid_price    = 0.05
base_node_count   = 1

# GPU burst (set to true when needed, false to destroy)
gpu_enabled      = false
gpu_server_class = "gpu.vs1.large-iad"  # Check actual available classes first
gpu_bid_price    = 0.50
gpu_node_count   = 1
