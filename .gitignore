# Security
*.pem
*.key
id_rsa*
credentials.json
secrets.yaml

# Ansible Vault - Deployment-Specific
provision/ansible/roles/secrets/vars/vault.yml
provision/ansible/roles/secrets/vars/vault.*.yml
!provision/ansible/roles/secrets/vars/vault.example.yml
provision/ansible/roles/secrets/vars/backups/
*.yml.bak
ssl

# Local installation config (generated from state file, contains network octets)
provision/ansible/inventory/*/group_vars/all/local.yml

# Machine-generated model configuration
provision/ansible/group_vars/all/model_config.yml

# Busibox state files (user-specific, stores env preferences)
# Used by both the interactive menu (scripts/make/menu.sh) and Makefile
# Environment-prefixed to allow multiple installations to coexist:
#   .busibox-state-demo, .busibox-state-dev, .busibox-state-staging, .busibox-state-prod
.busibox-state
.busibox-state-*

# Vault password files (created in repo root when running inside manager container)
.busibox-vault-pass-*

# Ephemeral setup link file (magic link displayed after install)
.busibox-setup-link

# MLX setup marker (triggers host-side MLX install after container exits)
.mlx-setup-needed

# Deployment profiles directory (local workstation state)
# Contains profiles.json, per-profile state files, env files, kubeconfigs
.busibox/

# Demo mode generated files
config/litellm-demo.yaml

# Nginx app routes (generated by deploy-api)
config/nginx-sites/apps/*
!config/nginx-sites/apps/.gitkeep

# Dev apps directory - local development only
# Contains symlinks to local app source for hot-reload development
dev-apps/*
!dev-apps/.gitkeep
!dev-apps/README.md

# Profile export bundles (contain encrypted secrets)
*.busibox-export

# Rust build artifacts
cli/busibox/target/

# Kubernetes - sensitive files
k8s/kubeconfig-*.yaml
k8s/secrets/secrets.yaml
k8s/overlays/*/ai-capabilities-patch.yaml
k8s/terraform/*.tfvars
k8s/terraform/.terraform/
k8s/terraform/*.tfstate*
provision/.cache/*
