# =============================================================================
# LiteLLM Configuration for Busibox Demo Mode
# =============================================================================
#
# Generated by demo setup - do not edit manually
# System: {{DEMO_RAM_GB}}GB RAM, Tier: {{DEMO_TIER}}, Backend: {{DEMO_BACKEND}}
#
# This configuration routes all LLM requests to the local inference server
# (MLX-LM on Apple Silicon, vLLM on x86/Linux).
#
# =============================================================================

model_list:
  # Fast model - for quick tasks, tool calls, simple operations
  - model_name: fast
    litellm_params:
      model: openai/{{DEMO_MODEL_FAST}}
      api_base: http://host.docker.internal:18081/v1
      api_key: demo
    model_info:
      description: "Fast local model for simple tasks"

  # Classify model alias (uses fast model on dedicated fast server)
  - model_name: classify
    litellm_params:
      model: openai/{{DEMO_MODEL_FAST}}
      api_base: http://host.docker.internal:18081/v1
      api_key: demo
    model_info:
      description: "Fast classifier model alias"

  # Test model alias (uses fast model on dedicated fast server)
  - model_name: test
    litellm_params:
      model: openai/{{DEMO_MODEL_FAST}}
      api_base: http://host.docker.internal:18081/v1
      api_key: demo
    model_info:
      description: "Fast test model alias"

  # Agent model - balanced for reasoning and tool use
  - model_name: agent
    litellm_params:
      model: openai/{{DEMO_MODEL_AGENT}}
      api_base: http://host.docker.internal:8080/v1
      api_key: demo
    model_info:
      description: "Agent model for complex reasoning"

  # Chat model alias (uses agent model)
  - model_name: chat
    litellm_params:
      model: openai/{{DEMO_MODEL_AGENT}}
      api_base: http://host.docker.internal:8080/v1
      api_key: demo
    model_info:
      description: "Chat model for conversations"

  # Frontier model - best quality for complex analysis
  - model_name: frontier
    litellm_params:
      model: openai/{{DEMO_MODEL_FRONTIER}}
      api_base: http://host.docker.internal:8080/v1
      api_key: demo
    model_info:
      description: "Frontier model for complex analysis"

# ===========================================================================
# GENERAL SETTINGS
# ===========================================================================

general_settings:
  # Enable detailed logging for demo
  debug: true
  
  # Master key for admin access
  master_key: demo-key
  
  # Allow all models (no restrictions)
  allow_user_auth: true

# ===========================================================================
# ROUTER SETTINGS
# ===========================================================================

router_settings:
  # Enable caching for repeated requests
  enable_cache: true
  
  # Retry configuration
  num_retries: 3
  retry_after: 5
  
  # Timeout settings (in seconds) - longer for local inference
  timeout: 120
  
  # Allow fallbacks between models
  allowed_fails: 1

# ===========================================================================
# LITELLM SETTINGS
# ===========================================================================

litellm_settings:
  # Drop unmapped params (for compatibility)
  drop_params: true
  
  # Set modest timeouts
  request_timeout: 120
  
  # Enable streaming
  set_verbose: true
