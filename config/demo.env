# =============================================================================
# Busibox Demo Mode Environment Configuration
# =============================================================================
#
# Zero-config environment for demo mode. All values are pre-set defaults
# suitable for local demonstration. DO NOT use these values in production.
#
# Usage:
#   cp config/demo.env .env.local
#   make demo
#
# =============================================================================

# Demo mode flag
DEMO_MODE=true

# =============================================================================
# DATABASE
# =============================================================================

POSTGRES_USER=busibox_user
POSTGRES_PASSWORD=demo

# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# LiteLLM master key (for admin access)
LITELLM_MASTER_KEY=demo-key

# API key for services to use with LiteLLM
LITELLM_API_KEY=demo-key

# No cloud API keys needed - using local inference
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# AUTHZ CONFIGURATION
# =============================================================================

# Admin token for authz service (internal API access)
AUTHZ_ADMIN_TOKEN=demo-admin

# Master key for envelope encryption
AUTHZ_MASTER_KEY=demo-master-key

# Access token TTL in seconds (15 minutes default)
AUTHZ_ACCESS_TOKEN_TTL=900

# Bootstrap OAuth client (ai-portal)
AUTHZ_BOOTSTRAP_CLIENT_ID=ai-portal
AUTHZ_BOOTSTRAP_CLIENT_SECRET=demo-secret

# =============================================================================
# AI PORTAL CONFIGURATION
# =============================================================================

# Better Auth secret
BETTER_AUTH_SECRET=demo-auth-secret

# SSO JWT secret (for app-to-app authentication)
SSO_JWT_SECRET=demo-sso-secret

# Admin email (first user to sign up gets admin access)
ADMIN_EMAIL=demo@localhost

# Allowed email domains (* for any)
ALLOWED_EMAIL_DOMAINS=*

# Email provider (console logging in demo mode)
RESEND_API_KEY=
EMAIL_FROM=noreply@localhost

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# Agent API OAuth client credentials
AGENT_API_CLIENT_ID=agent-api
AGENT_API_CLIENT_SECRET=demo-agent-secret

# Agent Manager OAuth client credentials
AGENT_MANAGER_CLIENT_ID=agent-manager
AGENT_MANAGER_CLIENT_SECRET=demo-manager-secret

# =============================================================================
# PROCESSING OPTIONS
# =============================================================================

# Marker PDF extraction (enabled but no GPU)
MARKER_ENABLED=true
MARKER_USE_GPU=false

# ColPali visual embeddings (disabled for demo)
COLPALI_ENABLED=false

# LLM cleanup for extracted text
LLM_CLEANUP_ENABLED=true

# Reranking (disabled for faster demo)
ENABLE_RERANKING=false
RERANKING_MODE=none

# FastEmbed model - use small model for faster startup
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
