<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="Electron" modified="2026-04-23T00:00:00.000Z" agent="Busibox-Docs" version="24.0.0" type="device">
  <diagram id="page-overview" name="0. Overview — Two-Dimensional Access Control">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="ov_title" value="Busibox Access Control — Two Orthogonal Dimensions" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="30" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="ov_req" value="Incoming Request&#xa;Authorization: Bearer &lt;access_token&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="550" y="100" width="300" height="60" as="geometry"/></mxCell>
        <mxCell id="ov_rbac_box" value="RBAC — &quot;What can I do?&quot;&#xa;(Operations)" style="swimlane;fontSize=14;fontStyle=1;startSize=40;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="100" y="210" width="580" height="420" as="geometry"/></mxCell>
        <mxCell id="ov_rbac_1" value="JWT scopes (OAuth2) aggregated from&#xa;all user roles at token-exchange time" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="ov_rbac_box"><mxGeometry x="30" y="60" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rbac_2" value="Route dependency ScopeChecker(&quot;data.write&quot;)&#xa;→ 403 if missing; wildcard * matches all" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="ov_rbac_box"><mxGeometry x="30" y="130" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rbac_3" value="Standard scopes: data.read, data.write,&#xa;data.delete, data.admin, search.*, agent.*" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="ov_rbac_box"><mxGeometry x="30" y="200" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rbac_4" value="Admin role carries wildcard &quot;*&quot; — the only&#xa;role that matches data.admin today" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="ov_rbac_box"><mxGeometry x="30" y="270" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rbac_5" value="Enforced in:&#xa;srv/shared/busibox_common/auth.py:633-726" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" vertex="1" parent="ov_rbac_box"><mxGeometry x="30" y="340" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rls_box" value="RLS — &quot;Which rows can I see?&quot;&#xa;(Data)" style="swimlane;fontSize=14;fontStyle=1;startSize=40;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="720" y="210" width="580" height="420" as="geometry"/></mxCell>
        <mxCell id="ov_rls_1" value="JWT roles[].id → PostgreSQL session vars&#xa;app.user_id, app.user_role_ids_read/create/update/delete" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="ov_rls_box"><mxGeometry x="30" y="60" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rls_2" value="FORCE ROW LEVEL SECURITY on every&#xa;data table (even table owner is filtered)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="ov_rls_box"><mxGeometry x="30" y="130" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rls_3" value="Visibility modes: personal / shared / authenticated&#xa;→ bindings in document_roles &amp; record_roles" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="ov_rls_box"><mxGeometry x="30" y="200" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rls_4" value="Admin bypass: app.is_admin = 'true' set by&#xa;app code AFTER verifying data.admin scope" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="ov_rls_box"><mxGeometry x="30" y="270" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_rls_5" value="Enforced in Postgres:&#xa;provision/ansible/roles/postgres/data/migrations/002_add_rls_policies.sql" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" vertex="1" parent="ov_rls_box"><mxGeometry x="30" y="340" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_and" value="BOTH must pass" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="600" y="670" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="ov_note" value="Missing scope → 403 at route&#xa;Missing row match → empty list / 404 (silent RLS filter)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="450" y="750" width="500" height="60" as="geometry"/></mxCell>
        <mxCell id="ov_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ov_req" target="ov_rbac_box"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ov_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ov_req" target="ov_rls_box"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ov_e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ov_rbac_box" target="ov_and"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ov_e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ov_rls_box" target="ov_and"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ov_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ov_and" target="ov_note"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-uc1" name="UC-1. User Login &amp; JWT Issuance (Flow)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="uc1_title" value="UC-1: User Login &amp; Session JWT Issuance" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="uc1_start" value="User opens login page" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="580" y="80" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="uc1_d1" value="Credential type?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="580" y="170" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="uc1_p_pk" value="POST /auth/passkeys/authenticate" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="120" y="290" width="260" height="50" as="geometry"/></mxCell>
        <mxCell id="uc1_p_totp" value="POST /auth/totp/verify" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="550" y="290" width="260" height="50" as="geometry"/></mxCell>
        <mxCell id="uc1_p_ml" value="POST /auth/magic-link/verify" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="980" y="290" width="260" height="50" as="geometry"/></mxCell>
        <mxCell id="uc1_p_verify" value="AuthZ verifies credential&#xa;(public endpoint — IS the auth)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="580" y="380" width="200" height="60" as="geometry"/></mxCell>
        <mxCell id="uc1_d2" value="Credential valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="580" y="470" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="uc1_fail" value="401 Unauthorized&#xa;audit: user.login.failed" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="1080" y="485" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="uc1_db1" value="authz_users&#xa;SELECT user_id WHERE email = ?" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="580" y="580" width="200" height="70" as="geometry"/></mxCell>
        <mxCell id="uc1_db2" value="authz_user_roles JOIN authz_roles&#xa;SELECT roles FOR user_id" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="580" y="680" width="200" height="70" as="geometry"/></mxCell>
        <mxCell id="uc1_build" value="Build JWT claims&#xa;iss=busibox-authz, sub=user_id,&#xa;aud=busibox-portal, typ=session,&#xa;roles=[{id,name}...], exp=now+7d, jti" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="540" y="780" width="280" height="90" as="geometry"/></mxCell>
        <mxCell id="uc1_sign" value="Sign with RS256 private key&#xa;(keys rotated via authz JWKS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="580" y="900" width="200" height="60" as="geometry"/></mxCell>
        <mxCell id="uc1_cookie" value="Portal sets busibox-session cookie&#xa;(HttpOnly, Secure, SameSite)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="990" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="uc1_end" value="Authenticated session" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="580" y="1060" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="uc1_note" value="Source:&#xa;srv/authz/src/routes/auth.py:85-145&#xa;Session TTL: AUTHZ_SESSION_TOKEN_TTL (default 7d)&#xa;JTI recorded in authz_sessions for revocation" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" vertex="1" parent="1"><mxGeometry x="120" y="780" width="360" height="110" as="geometry"/></mxCell>
        <mxCell id="uc1_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_start" target="uc1_d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e2" value="passkey" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_d1" target="uc1_p_pk"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e3" value="TOTP" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_d1" target="uc1_p_totp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e4" value="magic link" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_d1" target="uc1_p_ml"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_p_pk" target="uc1_p_verify"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_p_totp" target="uc1_p_verify"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_p_ml" target="uc1_p_verify"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_p_verify" target="uc1_d2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e9" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_d2" target="uc1_fail"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e10" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_d2" target="uc1_db1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_db1" target="uc1_db2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_db2" target="uc1_build"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_build" target="uc1_sign"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_sign" target="uc1_cookie"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc1_e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc1_cookie" target="uc1_end"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-session-state" name="UC-1 State. Session JWT Lifecycle">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="ss_title" value="Session JWT — State Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="ss_anon" value="Anonymous" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="100" y="400" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="ss_auth" value="Authenticated&#xa;(session JWT held)&#xa;7-day TTL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="450" y="400" width="200" height="90" as="geometry"/></mxCell>
        <mxCell id="ss_acc" value="Has Access Token&#xa;(audience-bound)&#xa;15-min TTL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="780" y="400" width="200" height="90" as="geometry"/></mxCell>
        <mxCell id="ss_rev" value="Revoked&#xa;(JTI in authz_sessions&#xa;marked revoked)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="780" y="160" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="ss_exp" value="Expired&#xa;(exp &lt; now)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="780" y="640" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="ss_note" value="Access-token refresh can happen silently many times&#xa;during the 7-day session. Role revocation takes full effect&#xa;on next token exchange (&lt;= 15 min)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" vertex="1" parent="1"><mxGeometry x="100" y="640" width="520" height="80" as="geometry"/></mxCell>
        <mxCell id="ss_e1" value="login succeeds" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ss_anon" target="ss_auth"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ss_e2" value="token exchange&#xa;subject_token=sessionJWT" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ss_auth" target="ss_acc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ss_e3" value="access token expires&#xa;(re-exchange)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ss_acc" target="ss_auth"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ss_e4" value="logout / admin revoke" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ss_auth" target="ss_rev"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ss_e5" value="7 days elapse" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ss_auth" target="ss_exp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ss_e6" value="re-login" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ss_exp" target="ss_anon"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ss_e7" value="re-login" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ss_rev" target="ss_anon"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-uc2" name="UC-2. API Request — RBAC + RLS Lifecycle (Flow)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="uc2_title" value="UC-2: API Request → JWT Validation → RBAC Check → RLS Enforcement" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="uc2_start" value="Client → Service&#xa;Authorization: Bearer &lt;access_token&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="540" y="80" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc2_jwks" value="Fetch authz JWKS (cached)&#xa;GET /.well-known/jwks.json" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="180" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="uc2_verify" value="Verify RS256 signature&#xa;+ iss, exp, aud, nbf" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="270" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="uc2_d1" value="Signature &amp; claims valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="560" y="360" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="uc2_401" value="401 Unauthorized" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="900" y="375" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="uc2_ctx" value="Build UserContext:&#xa;user_id ← sub, roles[] ← roles claim,&#xa;scopes[] ← scopes claim" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="530" y="470" width="300" height="70" as="geometry"/></mxCell>
        <mxCell id="uc2_d2" value="has_scope(required)?&#xa;e.g. data.read / data.write" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="540" y="570" width="280" height="90" as="geometry"/></mxCell>
        <mxCell id="uc2_403" value="403 Forbidden" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="900" y="590" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="uc2_acq" value="acquire_with_rls(request)&#xa;↓&#xa;pool.acquire() → conn" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="700" width="240" height="70" as="geometry"/></mxCell>
        <mxCell id="uc2_set" value="SET app.user_id = '&lt;user_id&gt;'&#xa;SET app.user_role_ids_read = '&lt;csv&gt;'&#xa;SET app.user_role_ids_create = '&lt;csv&gt;'&#xa;SET app.user_role_ids_update = '&lt;csv&gt;'&#xa;SET app.user_role_ids_delete = '&lt;csv&gt;'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="520" y="800" width="320" height="120" as="geometry"/></mxCell>
        <mxCell id="uc2_d3" value="has_scope(&quot;data.admin&quot;)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="560" y="950" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="uc2_admin" value="SET app.is_admin = 'true'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="900" y="965" width="220" height="50" as="geometry"/></mxCell>
        <mxCell id="uc2_query" value="Execute query&#xa;(RLS policies filter rows automatically)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="540" y="1060" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc2_return" value="Return filtered result&#xa;(rows dropped by RLS are invisible; no error raised)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="520" y="1150" width="320" height="60" as="geometry"/></mxCell>
        <mxCell id="uc2_end" value="200 OK (or 404 if id-lookup filtered)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="540" y="1240" width="320" height="50" as="geometry"/></mxCell>
        <mxCell id="uc2_note" value="Sources:&#xa;• JWT/UserContext → srv/shared/busibox_common/auth.py:149-255&#xa;• Scope check → srv/shared/busibox_common/auth.py:633-726&#xa;• acquire_with_rls → srv/data/src/api/services/data_service.py:76-110&#xa;• Session vars SET → srv/shared/busibox_common/auth.py:546-626" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="900" width="400" height="160" as="geometry"/></mxCell>
        <mxCell id="uc2_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_start" target="uc2_jwks"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_jwks" target="uc2_verify"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_verify" target="uc2_d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e4" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_d1" target="uc2_401"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_d1" target="uc2_ctx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_ctx" target="uc2_d2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e7" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_d2" target="uc2_403"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e8" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_d2" target="uc2_acq"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_acq" target="uc2_set"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_set" target="uc2_d3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e11" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_d3" target="uc2_admin"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e12" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_d3" target="uc2_query"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_admin" target="uc2_query"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc2_e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc2_query" target="uc2_return"><mxGeometry relative="1" as="geometry"/></mxCell>
