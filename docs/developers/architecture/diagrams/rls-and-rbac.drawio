  <diagram id="page-uc3" name="UC-3. Document Upload with Visibility (Flow)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="uc3_title" value="UC-3: Document Upload — Visibility Selection, Storage, Role Binding" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="uc3_start" value="User selects file + visibility + role_ids[]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="540" y="80" width="300" height="50" as="geometry"/></mxCell>
        <mxCell id="uc3_xchg" value="App exchanges session JWT&#xa;for data-api access token" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="550" y="170" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc3_post" value="POST /files (multipart)&#xa;scope: data.write" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="570" y="260" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="uc3_auth" value="JWT validation + scope check&#xa;(see UC-2)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="570" y="350" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="uc3_d1" value="visibility ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="590" y="440" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="uc3_p_personal" value="MinIO path:&#xa;personal/{user_id}/{file_id}/..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="120" y="560" width="260" height="60" as="geometry"/></mxCell>
        <mxCell id="uc3_p_shared" value="MinIO path:&#xa;role/{primary_role_id}/{file_id}/..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="550" y="560" width="260" height="60" as="geometry"/></mxCell>
        <mxCell id="uc3_p_auth" value="MinIO path:&#xa;authenticated/{file_id}/..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="980" y="560" width="260" height="60" as="geometry"/></mxCell>
        <mxCell id="uc3_i_personal" value="INSERT data_files&#xa;owner_id=app.user_id,&#xa;visibility='personal'" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="140" y="660" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="uc3_i_shared" value="INSERT data_files&#xa;owner_id=app.user_id,&#xa;visibility='shared'" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="570" y="660" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="uc3_i_auth" value="INSERT data_files&#xa;owner_id=app.user_id,&#xa;visibility='authenticated'" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="1000" y="660" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="uc3_role_loop" value="For each role_id in role_ids:&#xa;INSERT INTO document_roles (file_id, role_id)&#xa;— policy requires role_id ∈ user_role_ids_create" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="530" y="780" width="310" height="90" as="geometry"/></mxCell>
        <mxCell id="uc3_enc" value="Optional envelope encryption:&#xa;wrap per-file DEK with each role KEK&#xa;(authz keystore /keystore/file/{id}/add-role/{role})" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" vertex="1" parent="1"><mxGeometry x="520" y="910" width="340" height="70" as="geometry"/></mxCell>
        <mxCell id="uc3_end" value="200 OK { file_id, visibility }" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="570" y="1020" width="240" height="50" as="geometry"/></mxCell>
        <mxCell id="uc3_note" value="data_files_insert policy:&#xa;USING (owner_id = current_setting('app.user_id')::uuid)&#xa;→ users cannot forge ownership; the row is&#xa;automatically attributed to the caller." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="880" width="380" height="110" as="geometry"/></mxCell>
        <mxCell id="uc3_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_start" target="uc3_xchg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_xchg" target="uc3_post"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_post" target="uc3_auth"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_auth" target="uc3_d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e5" value="personal" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_d1" target="uc3_p_personal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e6" value="shared" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_d1" target="uc3_p_shared"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e7" value="authenticated" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_d1" target="uc3_p_auth"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_p_personal" target="uc3_i_personal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_p_shared" target="uc3_i_shared"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_p_auth" target="uc3_i_auth"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_i_shared" target="uc3_role_loop"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_role_loop" target="uc3_enc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_enc" target="uc3_end"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_i_personal" target="uc3_end"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc3_e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc3_i_auth" target="uc3_end"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-doc-state" name="UC-3 State. Document Visibility Lifecycle">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="ds_title" value="Document — Visibility State Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="ds_init" value="• (start)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="650" y="100" width="60" height="60" as="geometry"/></mxCell>
        <mxCell id="ds_personal" value="Personal&#xa;visibility='personal'&#xa;document_roles = ∅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="580" y="220" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="ds_sharedApp" value="SharedApp&#xa;visibility='shared'&#xa;document_roles ⊇ {app:X}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="400" width="240" height="90" as="geometry"/></mxCell>
        <mxCell id="ds_sharedTeam" value="SharedTeam&#xa;visibility='shared'&#xa;document_roles ⊇ {app:X:team-Y}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="580" y="400" width="240" height="90" as="geometry"/></mxCell>
        <mxCell id="ds_authenticated" value="Authenticated&#xa;visibility='authenticated'&#xa;document_roles = ∅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="980" y="400" width="240" height="90" as="geometry"/></mxCell>
        <mxCell id="ds_mixed" value="Mixed Shared&#xa;visibility='shared'&#xa;document_roles ⊇ {app:X, team-Y, ...}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="580" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="ds_deleted" value="Deleted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="640" y="820" width="160" height="60" as="geometry"/></mxCell>
        <mxCell id="ds_note" value="BEFORE DELETE trigger 'ensure_document_has_roles' prevents deleting the&#xa;last role from a shared document. set_document_roles flips visibility to&#xa;'personal' first inside a transaction to work around this." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="820" width="480" height="90" as="geometry"/></mxCell>
        <mxCell id="ds_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_init" target="ds_personal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e2" value="add app role&#xa;+ set visibility='shared'" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_personal" target="ds_sharedApp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e3" value="add team role&#xa;+ set visibility='shared'" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_personal" target="ds_sharedTeam"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e4" value="set visibility='authenticated'" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_personal" target="ds_authenticated"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e5" value="+ team role" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_sharedApp" target="ds_mixed"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e6" value="+ app role" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_sharedTeam" target="ds_mixed"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e7" value="remove team role(s)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_mixed" target="ds_sharedApp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e8" value="remove app role" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_mixed" target="ds_sharedTeam"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e9" value="set visibility='personal'&#xa;(trigger: flip first, then drop roles)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_sharedApp" target="ds_personal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e10" value="set visibility='personal'" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_sharedTeam" target="ds_personal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e11" value="set visibility='personal'" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_authenticated" target="ds_personal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e12" value="DELETE" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_personal" target="ds_deleted"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ds_e13" value="DELETE" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="ds_mixed" target="ds_deleted"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-uc4" name="UC-4. Document Retrieval — RLS Policy Evaluation (Flow)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="uc4_title" value="UC-4: Document Retrieval — RLS Policy Evaluation per Row" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="uc4_start" value="SELECT * FROM data_files&#xa;(session vars already SET)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="520" y="90" width="320" height="60" as="geometry"/></mxCell>
        <mxCell id="uc4_row" value="Postgres evaluates policies for each row&#xa;(OR of all applicable SELECT policies)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="500" y="180" width="360" height="60" as="geometry"/></mxCell>
        <mxCell id="uc4_d1" value="admin_docs_select&#xa;app.is_admin = 'true' ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="540" y="280" width="280" height="80" as="geometry"/></mxCell>
        <mxCell id="uc4_d2" value="personal_docs_select&#xa;visibility='personal' AND owner_id=app.user_id ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="480" y="400" width="400" height="90" as="geometry"/></mxCell>
        <mxCell id="uc4_d3" value="shared_docs_select&#xa;visibility='shared' AND&#xa;EXISTS(document_roles WHERE&#xa;role_id ∈ user_role_ids_read) ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="470" y="530" width="420" height="110" as="geometry"/></mxCell>
        <mxCell id="uc4_d4" value="authenticated_docs_select&#xa;visibility='authenticated' AND&#xa;app.user_id IS NOT NULL ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="480" y="680" width="400" height="110" as="geometry"/></mxCell>
        <mxCell id="uc4_pass" value="Row included in result set" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1000" y="420" width="280" height="50" as="geometry"/></mxCell>
        <mxCell id="uc4_drop" value="Row silently filtered&#xa;(invisible to caller;&#xa;lookup-by-id returns 404)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="520" y="850" width="320" height="80" as="geometry"/></mxCell>
        <mxCell id="uc4_note" value="Tip: because RLS filters silently, there is no error-based way to tell&#xa;&quot;does not exist&quot; from &quot;exists but you can't see it.&quot; Admins debugging&#xa;missing-doc reports should use acquire_admin and compare counts." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="970" width="600" height="90" as="geometry"/></mxCell>
        <mxCell id="uc4_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_start" target="uc4_row"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_row" target="uc4_d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e3" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_d1" target="uc4_pass"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e4" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_d1" target="uc4_d2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_d2" target="uc4_pass"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e6" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_d2" target="uc4_d3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e7" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_d3" target="uc4_pass"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e8" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_d3" target="uc4_d4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e9" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_d4" target="uc4_pass"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc4_e10" value="no (all policies failed)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc4_d4" target="uc4_drop"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-uc5" name="UC-5. Role Creation &amp; Assignment (Flow)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="uc5_title" value="UC-5: Role Creation &amp; Assignment — Admin vs Self-Service" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1200" height="40" as="geometry"/></mxCell>
        <mxCell id="uc5_start" value="Caller wants to create or assign a role" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="640" y="80" width="320" height="50" as="geometry"/></mxCell>
        <mxCell id="uc5_d1" value="Caller has&#xa;authz.roles.write&#xa;scope?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="660" y="170" width="280" height="100" as="geometry"/></mxCell>
        <mxCell id="uc5_adm_post" value="POST /admin/roles&#xa;body: { name, scopes, description }" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="140" y="320" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc5_adm_ins" value="INSERT INTO authz_roles&#xa;(any name, any scope set)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="160" y="410" width="240" height="70" as="geometry"/></mxCell>
        <mxCell id="uc5_adm_assign" value="POST /admin/user-roles&#xa;body: { user_id, role_id }" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="140" y="510" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc5_adm_ins2" value="INSERT INTO authz_user_roles" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="160" y="600" width="240" height="60" as="geometry"/></mxCell>
        <mxCell id="uc5_self_post" value="POST /roles&#xa;body: { name: 'app:{app}:{entity}', scopes }&#xa;(session JWT required)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="1180" y="320" width="320" height="70" as="geometry"/></mxCell>
        <mxCell id="uc5_self_dpat" value="Name matches&#xa;^app:[a-z0-9...]:[a-z0-9...]$ ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1200" y="420" width="280" height="90" as="geometry"/></mxCell>
        <mxCell id="uc5_self_dscope" value="All scopes in whitelist?&#xa;{data:read/write,&#xa;search:read/write, graph:*,&#xa;libraries:*}" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1200" y="550" width="280" height="130" as="geometry"/></mxCell>
        <mxCell id="uc5_400" value="400 Bad Request" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="1520" y="480" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="uc5_self_ins" value="INSERT INTO authz_roles&#xa;(owned by session user)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="1220" y="720" width="240" height="70" as="geometry"/></mxCell>
        <mxCell id="uc5_self_mem" value="POST /roles/{id}/members&#xa;INSERT authz_user_roles" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="1200" y="820" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc5_merge" value="Role now exists and members bound&#xa;Effect appears in JWT on next token exchange (≤15 min)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="580" y="940" width="440" height="70" as="geometry"/></mxCell>
        <mxCell id="uc5_403" value="403 Forbidden&#xa;(not admin)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="660" y="1080" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc5_note" value="Admin path: srv/authz/src/routes/admin.py&#xa;Self-service path: srv/authz/src/routes/roles.py:41-48" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="600" y="1160" width="400" height="60" as="geometry"/></mxCell>
        <mxCell id="uc5_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_start" target="uc5_d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e2" value="yes (admin)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_d1" target="uc5_adm_post"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e3" value="no (self-service)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_d1" target="uc5_self_post"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_adm_post" target="uc5_adm_ins"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_adm_ins" target="uc5_adm_assign"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_adm_assign" target="uc5_adm_ins2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_adm_ins2" target="uc5_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_self_post" target="uc5_self_dpat"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e9" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_self_dpat" target="uc5_400"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e10" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_self_dpat" target="uc5_self_dscope"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e11" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_self_dscope" target="uc5_400"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e12" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_self_dscope" target="uc5_self_ins"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_self_ins" target="uc5_self_mem"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc5_e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc5_self_mem" target="uc5_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-role-state" name="UC-5 State. Role Lifecycle (Creation → Active → Deleted)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="rs_title" value="Role — Lifecycle State Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="rs_init" value="• (start)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="150" y="400" width="60" height="60" as="geometry"/></mxCell>
        <mxCell id="rs_created" value="Created&#xa;authz_roles row exists&#xa;no members, no bindings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="290" y="390" width="240" height="90" as="geometry"/></mxCell>
        <mxCell id="rs_members" value="HasMembers&#xa;authz_user_roles has entries&#xa;(but no documents tagged)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="600" y="180" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="rs_bound" value="BoundToDocuments&#xa;document_roles / record_roles&#xa;has entries (but no members)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="600" y="600" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="rs_active" value="Active&#xa;Members ≥ 1 AND&#xa;bound to ≥ 1 doc/record&#xa;— effective access enforced" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="950" y="390" width="280" height="100" as="geometry"/></mxCell>
        <mxCell id="rs_deleted" value="Deleted&#xa;(authz_roles row removed;&#xa;cascades to authz_user_roles,&#xa;document_roles)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1280" y="790" width="240" height="100" as="geometry"/></mxCell>
        <mxCell id="rs_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_init" target="rs_created"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e2" value="add member" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_created" target="rs_members"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e3" value="bind to document" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_created" target="rs_bound"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e4" value="bind to document" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_members" target="rs_active"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e5" value="add member" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_bound" target="rs_active"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e6" value="remove last binding" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_active" target="rs_members"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e7" value="remove last member" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_active" target="rs_bound"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e8" value="remove all members" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_members" target="rs_created"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e9" value="remove all bindings" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_bound" target="rs_created"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e10" value="DELETE role" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_active" target="rs_deleted"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e11" value="DELETE role" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_created" target="rs_deleted"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e12" value="DELETE role" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_members" target="rs_deleted"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_e13" value="DELETE role" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="rs_bound" target="rs_deleted"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rs_note" value="&quot;Effective access&quot; requires BOTH member binding AND document binding.&#xa;A user in HasMembers (but no BoundToDocuments) sees no rows via RLS." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="100" y="800" width="700" height="70" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-uc6" name="UC-6. Team Member Addition — Two-Step Gotcha (Flow)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="uc6_title" value="UC-6: Team Member Addition — Adding a User to a Role is NOT Enough" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="100" y="20" width="1200" height="40" as="geometry"/></mxCell>
        <mxCell id="uc6_start" value="Admin wants User X on Team T&#xa;(T already exists)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="540" y="80" width="320" height="60" as="geometry"/></mxCell>
        <mxCell id="uc6_s1" value="STEP 1: Add member&#xa;POST /roles/{T}/members { userId: X }&#xa;→ INSERT authz_user_roles" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="520" y="180" width="360" height="80" as="geometry"/></mxCell>
        <mxCell id="uc6_d1" value="Is T already present in&#xa;document_roles for every&#xa;document the team should see?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="500" y="300" width="400" height="120" as="geometry"/></mxCell>
        <mxCell id="uc6_bad" value="X HAS role T in JWT&#xa;but RLS denies (document_roles miss)&#xa;→ X sees 404 for all team documents&#xa;— common silent bug!" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="80" y="460" width="400" height="100" as="geometry"/></mxCell>
        <mxCell id="uc6_s2" value="STEP 2: Bind role to documents&#xa;addRoleToDocuments(dataToken, T, docIds[])&#xa;→ INSERT document_roles (file_id, role_id) for each doc&#xa;(idempotent — safe to re-run)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="500" y="600" width="400" height="110" as="geometry"/></mxCell>
        <mxCell id="uc6_good" value="Role-to-document bindings in place" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="540" y="750" width="320" height="60" as="geometry"/></mxCell>
        <mxCell id="uc6_refresh" value="X's session JWT → new access token&#xa;(next token exchange, ≤15 min)&#xa;roles claim now includes T" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="540" y="850" width="320" height="80" as="geometry"/></mxCell>
        <mxCell id="uc6_end" value="X can now read/modify team docs" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="560" y="960" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc6_note" value="Helpers in @jazzmind/busibox-app/lib/data/sharing:&#xa;  • addRoleToDocuments(dataToken, roleId, docIds[])&#xa;  • addRoleToLibrary(dataToken, roleId, libraryId)&#xa;&#xa;For entity-level sharing: add role to BOTH entity docs and app-level docs." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="960" width="440" height="120" as="geometry"/></mxCell>
        <mxCell id="uc6_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc6_start" target="uc6_s1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc6_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc6_s1" target="uc6_d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc6_e3" value="no (gotcha!)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#b85450;" edge="1" parent="1" source="uc6_d1" target="uc6_bad"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc6_e4" value="fix" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc6_bad" target="uc6_s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc6_e5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc6_d1" target="uc6_good"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc6_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc6_s2" target="uc6_good"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc6_e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc6_good" target="uc6_refresh"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc6_e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc6_refresh" target="uc6_end"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-uc7" name="UC-7. Token Exchange — App-Scoped vs Default (Flow)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="uc7_title" value="UC-7: OAuth2 Token Exchange (RFC 8693) — Roles in Access Token" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1000" height="40" as="geometry"/></mxCell>
        <mxCell id="uc7_start" value="Caller holds session JWT&#xa;Needs access token for specific service" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="520" y="80" width="360" height="60" as="geometry"/></mxCell>
        <mxCell id="uc7_post" value="POST /oauth/token&#xa;grant_type=urn:ietf:params:oauth:grant-type:token-exchange&#xa;subject_token=&lt;session_JWT&gt;&#xa;audience=data-api (or other)&#xa;resource_id=&lt;app-uuid&gt; (optional)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="450" y="180" width="500" height="140" as="geometry"/></mxCell>
        <mxCell id="uc7_verify" value="AuthZ verifies subject_token signature&#xa;(RS256, must be session JWT it issued)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="500" y="350" width="400" height="60" as="geometry"/></mxCell>
        <mxCell id="uc7_d1" value="resource_id provided?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="560" y="440" width="280" height="80" as="geometry"/></mxCell>
        <mxCell id="uc7_def_lookup" value="Default exchange:&#xa;SELECT ALL roles from&#xa;authz_user_roles WHERE user_id = sub" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="120" y="580" width="360" height="80" as="geometry"/></mxCell>
        <mxCell id="uc7_app_lookup" value="App-scoped exchange:&#xa;SELECT roles bound to the app&#xa;(e.g., via app-role mapping)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="940" y="580" width="340" height="80" as="geometry"/></mxCell>
        <mxCell id="uc7_agg" value="Aggregate scopes from selected roles&#xa;(union of all role.scopes)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="510" y="700" width="380" height="60" as="geometry"/></mxCell>
        <mxCell id="uc7_build" value="Build access-token claims:&#xa;iss, sub=user_id, aud=target,&#xa;roles=[{id,name}...], scopes=[...],&#xa;exp=now+15m, jti" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="520" y="790" width="360" height="110" as="geometry"/></mxCell>
        <mxCell id="uc7_sign" value="Sign RS256 → return access_token" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="520" y="930" width="360" height="50" as="geometry"/></mxCell>
        <mxCell id="uc7_end" value="200 OK { access_token, token_type, expires_in }" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="500" y="1010" width="400" height="50" as="geometry"/></mxCell>
        <mxCell id="uc7_note" value="Key fact: scopes/roles are looked up FROM the authz DB at exchange&#xa;time — never copied from the subject token. This is why revoking a&#xa;role takes effect within one access-token TTL window (15 min max).&#xa;&#xa;Source: srv/authz/src/routes/oauth.py:500-634" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="780" width="400" height="160" as="geometry"/></mxCell>
        <mxCell id="uc7_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_start" target="uc7_post"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_post" target="uc7_verify"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_verify" target="uc7_d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e4" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_d1" target="uc7_def_lookup"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_d1" target="uc7_app_lookup"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_def_lookup" target="uc7_agg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_app_lookup" target="uc7_agg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_agg" target="uc7_build"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_build" target="uc7_sign"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc7_e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc7_sign" target="uc7_end"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-uc8" name="UC-8. Admin Override (Flow)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="uc8_title" value="UC-8: Admin Override — Two-Gate Authorization (Scope + RLS Bypass)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="100" y="20" width="1200" height="40" as="geometry"/></mxCell>
        <mxCell id="uc8_start" value="Admin calls admin route&#xa;(e.g., GET /admin/documents)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="540" y="80" width="320" height="60" as="geometry"/></mxCell>
        <mxCell id="uc8_jwt" value="Standard JWT validation&#xa;(see UC-2)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="180" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc8_d1" value="user_context.has_scope(&quot;data.admin&quot;)?&#xa;(Admin role's * wildcard matches)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="520" y="280" width="360" height="100" as="geometry"/></mxCell>
        <mxCell id="uc8_403" value="403 Forbidden" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="1000" y="305" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="uc8_acq" value="acquire_admin(request)&#xa;(connection context manager)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="560" y="420" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="uc8_set1" value="SET app.user_id = '&lt;admin_id&gt;'&#xa;SET app.user_role_ids_* = '&lt;admin_roles_csv&gt;'&#xa;SET app.is_admin = 'true'     ← bypass flag" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="470" y="510" width="460" height="90" as="geometry"/></mxCell>
        <mxCell id="uc8_query" value="Execute query&#xa;(RLS admin_* policies match on is_admin;&#xa;all rows visible regardless of ownership)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="500" y="630" width="400" height="80" as="geometry"/></mxCell>
        <mxCell id="uc8_return" value="Return unfiltered rows" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="740" width="280" height="50" as="geometry"/></mxCell>
        <mxCell id="uc8_close" value="Connection closes&#xa;→ session vars (incl. is_admin) reset" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="540" y="820" width="320" height="60" as="geometry"/></mxCell>
        <mxCell id="uc8_end" value="200 OK [ {doc1}, {doc2}, ... ]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="560" y="910" width="320" height="50" as="geometry"/></mxCell>
        <mxCell id="uc8_note" value="Bypass rules:&#xa;• app.is_admin is NEVER read from the JWT — always set by app code&#xa;• Code must verify data.admin scope BEFORE setting is_admin&#xa;• Alternative: SET LOCAL app.is_admin = 'true' inside a transaction&#xa;  (used when admin needs to operate on specific docs they don't own)&#xa;• SELECT ... FOR UPDATE needs both select &amp; update admin policies to pass&#xa;&#xa;Sources:&#xa;  srv/data/src/api/services/data_service.py:76-110&#xa;  srv/shared/busibox_common/auth.py:546-626" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="700" width="380" height="270" as="geometry"/></mxCell>
        <mxCell id="uc8_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_start" target="uc8_jwt"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc8_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_jwt" target="uc8_d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc8_e3" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_d1" target="uc8_403"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc8_e4" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_d1" target="uc8_acq"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc8_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_acq" target="uc8_set1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc8_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_set1" target="uc8_query"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc8_e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_query" target="uc8_return"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc8_e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_return" target="uc8_close"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="uc8_e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;" edge="1" parent="1" source="uc8_close" target="uc8_end"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
