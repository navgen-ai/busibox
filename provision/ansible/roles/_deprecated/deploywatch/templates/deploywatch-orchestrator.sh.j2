#!/usr/bin/env bash
# Deploywatch Orchestrator
# Auto-generated by Ansible - modifications will be overwritten
# Purpose: Execute all application-specific deploywatch scripts
# Requirements: FR-010 (automatic redeployment on config changes)

set -euo pipefail

APPS_DIR="{{ deploywatch_apps_dir }}"
LOCK_FILE="/run/deploywatch/orchestrator.lock"
LOG_PREFIX="[deploywatch-orchestrator]"

# Logging functions
log_info() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] ${LOG_PREFIX} INFO: $*"
}

log_error() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] ${LOG_PREFIX} ERROR: $*" >&2
}

log_success() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] ${LOG_PREFIX} SUCCESS: $*"
}

# Ensure only one instance runs at a time
mkdir -p "$(dirname "${LOCK_FILE}")"
exec 9>"${LOCK_FILE}"
if ! flock -n 9; then
    log_info "Another instance is already running, exiting"
    exit 0
fi

# Create apps directory if it doesn't exist
mkdir -p "${APPS_DIR}"

log_info "Starting deployment check for all applications"
log_info "Apps directory: ${APPS_DIR}"

# Count apps
app_count=0
success_count=0
fail_count=0

# Find and execute all app scripts
while IFS= read -r -d '' script; do
    ((app_count++))
    
    app_name=$(basename "${script}" .sh)
    log_info "Processing application: ${app_name}"
    
    if [[ ! -x "${script}" ]]; then
        log_error "Script not executable: ${script}"
        chmod +x "${script}"
    fi
    
    if bash "${script}"; then
        ((success_count++))
        log_success "Completed: ${app_name}"
    else
        ((fail_count++))
        log_error "Failed: ${app_name}"
    fi
    
    echo ""  # Blank line for readability
    
done < <(find "${APPS_DIR}" -name "*.sh" -type f -print0 | sort -z)

# Summary
log_info "Deployment check complete"
log_info "Total applications: ${app_count}"
log_info "Successful: ${success_count}"
log_info "Failed: ${fail_count}"

if [[ ${fail_count} -gt 0 ]]; then
    exit 1
else
    exit 0
fi

