# Config API Environment Configuration
# Generated by Ansible - do not edit manually

# Service Configuration
CONFIG_PORT={{ config_api_service_port }}

# Environment
BUSIBOX_ENV={{ busibox_env | default(deployment_environment | default('staging')) }}

# Authz Service (for JWT validation)
AUTHZ_BASE_URL={{ config_api_authz_url }}

# PostgreSQL
POSTGRES_HOST={{ config_api_postgres_host }}
POSTGRES_PORT={{ config_api_postgres_port }}
POSTGRES_DB={{ config_api_postgres_db }}
POSTGRES_USER={{ config_api_postgres_user }}
POSTGRES_PASSWORD={{ config_api_postgres_password }}

# Encryption key for encrypted config values (AES-256-GCM)
CONFIG_ENCRYPTION_KEY={{ config_api_encryption_key }}
