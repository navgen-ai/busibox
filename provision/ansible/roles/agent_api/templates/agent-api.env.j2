# Agent API Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Application
APP_NAME=agent-server
ENVIRONMENT={{ busibox_env }}
DEBUG=false
LOG_LEVEL={{ log_level | default('INFO') }}

# Model Configuration
DEFAULT_MODEL={{ default_model }}

# Busibox Service Endpoints
SEARCH_API_URL={{ search_api_url }}
INGEST_API_URL={{ ingest_api_url }}
RAG_API_URL={{ rag_api_url }}

# Auth Configuration (authz-issued JWT tokens)
AUTH_JWKS_URL=http://{{ authz_ip }}:8010/.well-known/jwks.json
AUTH_ISSUER=busibox-authz
AUTH_AUDIENCE=agent-api
AUTH_TOKEN_URL=http://{{ authz_ip }}:8010/oauth/token
AUTH_CLIENT_ID={{ secrets['agent-server'].management_client_id }}
AUTH_CLIENT_SECRET={{ secrets['agent-server'].management_client_secret }}

# Database
DATABASE_URL={{ secrets['agent-server'].database_url }}

# Redis
REDIS_URL={{ secrets['agent-server'].redis_url }}

# CORS (JSON array format for Pydantic)
CORS_ORIGINS=["*"]

# LiteLLM
LITELLM_BASE_URL={{ litellm_base_url }}
LITELLM_API_KEY={{ secrets['agent-server'].litellm_api_key }}

# Bootstrap client credentials for PVT tests (from vault)
# ai-portal is the standard OAuth client used by all services
{% if secrets.authz is defined %}
AUTHZ_BOOTSTRAP_CLIENT_ID={{ secrets.authz.bootstrap_client_id | default('ai-portal') }}
AUTHZ_BOOTSTRAP_CLIENT_SECRET={{ secrets.authz.bootstrap_client_secret }}
{% endif %}






