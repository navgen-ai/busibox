# Agent API Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Application
APP_NAME=agent-server
ENVIRONMENT={{ busibox_env }}
DEBUG=false
LOG_LEVEL={{ log_level | default('INFO') }}

# Model Configuration
DEFAULT_MODEL={{ default_model }}

# Busibox Service Endpoints
SEARCH_API_URL={{ search_api_url }}
INGEST_API_URL={{ ingest_api_url }}
RAG_API_URL={{ rag_api_url }}

# Auth Configuration
AUTH_TOKEN_URL=http://{{ ansible_host }}:8080/oauth/token
AUTH_CLIENT_ID={{ secrets['agent-server'].management_client_id }}
AUTH_CLIENT_SECRET={{ secrets['agent-server'].management_client_secret }}

# Database
DATABASE_URL={{ secrets['agent-server'].database_url }}

# Redis
REDIS_URL={{ secrets['agent-server'].redis_url }}

# CORS (JSON array format for Pydantic)
CORS_ORIGINS=["*"]

# LiteLLM
LITELLM_BASE_URL={{ litellm_base_url }}
LITELLM_API_KEY={{ secrets['agent-server'].litellm_api_key }}


