# Agent API Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Application
APP_NAME=agent-server
ENVIRONMENT={{ busibox_env }}
DEBUG=false
LOG_LEVEL={{ log_level | default('INFO') }}

# Model Configuration
DEFAULT_MODEL={{ default_model }}

# Model Registry (for embedding config)
MODEL_REGISTRY_PATH={{ model_registry_path | default('/etc/data/model_registry.json') }}

# Embedding configuration (derived from model_registry.yml)
{% set embedding_model_key = (default_purposes | default({}) | combine(model_purposes | default({}))).embedding | default('nomic-embed') %}
{% set embedding_model_config = available_models[embedding_model_key] | default({}) %}
EMBEDDING_MODEL={{ embedding_model_config.model_name | default('nomic-ai/nomic-embed-text-v1.5') }}
EMBEDDING_DIMENSION={{ embedding_model_config.dimension | default(768) }}

# Busibox Service Endpoints
SEARCH_API_URL={{ search_api_url }}
DATA_API_URL={{ data_api_url }}
EMBEDDING_API_URL={{ embedding_api_url }}
RAG_API_URL={{ rag_api_url }}

# Milvus (for insights/memories)
MILVUS_HOST={{ milvus_ip }}
MILVUS_PORT=19530

# Neo4j graph database (for graph tools and entity extraction)
NEO4J_URI=bolt://{{ neo4j_host | default(neo4j_ip) }}:{{ neo4j_bolt_port | default('7687') }}
NEO4J_USER={{ neo4j_user | default('neo4j') }}
NEO4J_PASSWORD={{ busibox_secrets.NEO4J_PASSWORD }}

# Auth Configuration (authz-issued JWT tokens)
# Uses Zero Trust token exchange - no client credentials needed for token exchange.
# The user's JWT is passed as subject_token to get audience-bound tokens.
AUTH_JWKS_URL=http://{{ authz_ip }}:8010/.well-known/jwks.json
AUTH_ISSUER=busibox-authz
AUTH_AUDIENCE=agent-api
AUTH_TOKEN_URL=http://{{ authz_ip }}:8010/oauth/token

# Database (computed from base secrets)
DATABASE_URL=postgresql+asyncpg://{{ busibox_secrets.POSTGRES_USER }}:{{ busibox_secrets.POSTGRES_PASSWORD }}@{{ postgres_host }}:{{ postgres_port }}/agent

# Redis (computed from inventory)
REDIS_URL=redis://{{ redis_host }}:{{ redis_port }}

# CORS (use single * for all origins, or comma-separated list)
# Note: pydantic-settings parses JSON but bash sourcing can mangle quotes
# So we use the wildcard directly
CORS_ORIGINS='["*"]'

# LiteLLM (computed from base secrets)
LITELLM_BASE_URL={{ litellm_base_url }}
LITELLM_API_KEY={{ busibox_secrets.LITELLM_MASTER_KEY }}
# LiteLLM database for spend tracking (admin stats endpoint)
LITELLM_DATABASE_URL={{ litellm_database_url }}

# Deploy API (for MLX auto-start)
DEPLOY_API_URL=http://{{ deploy_host | default(authz_ip) }}:8011
# Config API (persistent encrypted config storage for cloud provider keys)
CONFIG_API_URL=http://{{ config_host | default(authz_ip) }}:{{ config_port }}
LLM_BACKEND={{ llm_backend | default('') }}

# Uses jwt_secret as the shared secret (same as authz service)
AUTHZ_JWKS_URL=http://{{ authz_ip }}:8010/.well-known/jwks.json
TEST_USER_ID={{ test_user_id | default('00000000-0000-0000-0000-000000000001') }}

# Email notifications - Bridge API (preferred) or direct SMTP as fallback
BRIDGE_API_URL=http://{{ bridge_ip | default(authz_ip) }}:{{ bridge_api_port | default('8081') }}
SMTP_HOST={{ secrets.smtp.host | default('') }}
SMTP_PORT={{ secrets.smtp.port | default('587') }}
SMTP_USERNAME={{ secrets.smtp.user | default('') }}
SMTP_PASSWORD={{ secrets.smtp.password | default('') }}
EMAIL_FROM={{ secrets.smtp.from_email | default('noreply@busibox.local') }}

# Portal URL (for notification links)
PORTAL_BASE_URL=https://{{ domain }}

# Skills system (AgentSkills-compatible SKILL.md loader)
SKILLS_ENABLED={{ skills_enabled | default(false) | lower }}
SKILLS_DIRS={{ skills_dirs | default('/srv/skills,~/.openclaw/skills,/skills') }}
SKILLS_CACHE_TTL_SECONDS={{ skills_cache_ttl_seconds | default(60) }}
SKILLS_ALLOWED_ROLES={{ skills_allowed_roles | default('') }}
SKILLS_CLAWHUB_ENABLED={{ skills_clawhub_enabled | default(false) | lower }}

# Calendar integration (optional)
GOOGLE_CALENDAR_ACCESS_TOKEN={{ google_calendar_access_token | default('') }}
GOOGLE_CALENDAR_ID={{ google_calendar_id | default('primary') }}


