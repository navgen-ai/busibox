[Unit]
Description=Agent API Service (Python/FastAPI)
After=network.target postgresql.service redis.service

[Service]
Type=simple
User={{ agent_api_user }}
Group={{ agent_api_user }}
WorkingDirectory={{ agent_api_src_path }}
Environment="PATH={{ agent_api_venv_path }}/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile={{ agent_api_src_path }}/.env
ExecStart={{ agent_api_venv_path }}/bin/uvicorn app.main:app --host 0.0.0.0 --port {{ agent_api_port }}
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agent-api

# Security
NoNewPrivileges=true
PrivateTmp=true

# Resource limits
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target








