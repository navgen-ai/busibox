#!/bin/bash
# Prisma Database Setup Script
# Generated by Ansible for {{ app_to_deploy.name }}
set -e

if [ ! -f "prisma/schema.prisma" ]; then
  echo "No Prisma schema found, skipping database setup"
  exit 0
fi

echo "========================================"
echo "DATABASE SETUP FOR {{ app_to_deploy.name }}"
echo "========================================"

# Load environment variables (DATABASE_URL, etc.)
if [ -f .env ]; then
  echo "Loading environment variables from .env"
  set -a
  source .env
  set +a
else
  echo "WARNING: No .env file found"
fi

# Check if DATABASE_URL is set
if [ -z "$DATABASE_URL" ]; then
  echo "ERROR: DATABASE_URL not set"
  exit 1
fi

# Show database URL (masked)
DB_HOST=$(echo "$DATABASE_URL" | sed -E 's/.*@([^:\/]+).*/\1/')
echo "Database host: $DB_HOST"

# Check if migrations directory exists and has migrations
if [ -d "prisma/migrations" ] && [ "$(ls -A prisma/migrations 2>/dev/null)" ]; then
  echo "Found migrations directory, attempting to deploy migrations..."
  
  if npx prisma migrate deploy 2>&1; then
    echo "✓ Migrations deployed successfully"
  else
    echo "✗ Migration deployment failed"
    echo "Attempting db push as fallback..."
    
    if npx prisma db push --skip-generate 2>&1; then
      echo "✓ Database schema pushed successfully"
    else
      echo "⚠ Schema push failed, trying with --accept-data-loss..."
      if npx prisma db push --skip-generate --accept-data-loss 2>&1; then
        echo "✓ Database schema pushed with data loss accepted"
      else
        echo "✗ Failed to push database schema"
        exit 1
      fi
    fi
  fi
else
  echo "No migrations found, using db push to create schema..."
  
  if npx prisma db push --skip-generate 2>&1; then
    echo "✓ Database schema created successfully"
  else
    echo "⚠ Schema push failed, trying with --accept-data-loss..."
    if npx prisma db push --skip-generate --accept-data-loss 2>&1; then
      echo "✓ Database schema pushed with data loss accepted"
    else
      echo "✗ Failed to create database schema"
      exit 1
    fi
  fi
fi

echo "========================================"
echo "DATABASE SETUP COMPLETE"
echo "========================================"

# Run any raw SQL migrations if they exist
if [ -d "prisma/migrations" ]; then
  SQL_FILES=$(find prisma/migrations -maxdepth 1 -name "*.sql" -type f 2>/dev/null | sort)
  if [ -n "$SQL_FILES" ]; then
    echo ""
    echo "========================================"
    echo "RUNNING RAW SQL MIGRATIONS"
    echo "========================================"
    
    for sql_file in $SQL_FILES; do
      echo "Running: $sql_file"
      if npx prisma db execute --file "$sql_file" 2>&1; then
        echo "✓ $sql_file executed successfully"
      else
        echo "⚠ $sql_file may have already been applied or failed (non-fatal)"
      fi
    done
    
    echo "========================================"
    echo "RAW SQL MIGRATIONS COMPLETE"
    echo "========================================"
  fi
fi

{% if busibox_env == 'test' %}
# Run database seeding in test environment
if [ -f "package.json" ] && grep -q '"db:seed"' package.json; then
  echo ""
  echo "========================================"
  echo "SEEDING DATABASE (TEST ENVIRONMENT)"
  echo "========================================"
  
  if npm run db:seed 2>&1; then
    echo "✓ Database seeded successfully"
  else
    echo "⚠ Database seeding failed (non-fatal)"
    # Don't fail deployment if seeding fails
  fi
fi
{% endif %}


