#!/bin/bash
# Prisma Database Setup Script
# Generated by Ansible for {{ app_to_deploy.name }}
set -e

if [ ! -f "prisma/schema.prisma" ]; then
  echo "No Prisma schema found, skipping database setup"
  exit 0
fi

echo "========================================"
echo "DATABASE SETUP FOR {{ app_to_deploy.name }}"
echo "========================================"

# Load environment variables (DATABASE_URL, etc.)
if [ -f .env ]; then
  echo "Loading environment variables from .env"
  set -a
  source .env
  set +a
else
  echo "WARNING: No .env file found"
fi

# Check if DATABASE_URL is set
if [ -z "$DATABASE_URL" ]; then
  echo "ERROR: DATABASE_URL not set"
  exit 1
fi

# Show database URL (masked)
DB_HOST=$(echo "$DATABASE_URL" | sed -E 's/.*@([^:\/]+).*/\1/')
echo "Database host: $DB_HOST"

# Run pre-migration SQL scripts if they exist
# These run BEFORE prisma db push to clean up data that might conflict with schema changes
PRE_MIGRATIONS_DIR="prisma/pre-migrations"
if [ -d "$PRE_MIGRATIONS_DIR" ]; then
  SQL_FILES=$(find "$PRE_MIGRATIONS_DIR" -maxdepth 1 -name "*.sql" -type f 2>/dev/null | sort)
  if [ -n "$SQL_FILES" ]; then
    echo ""
    echo "========================================"
    echo "RUNNING PRE-MIGRATION SQL SCRIPTS"
    echo "========================================"
    
    for sql_file in $SQL_FILES; do
      echo "Running: $sql_file"
      if npx prisma db execute --file "$sql_file" 2>&1; then
        echo "✓ $sql_file executed successfully"
      else
        echo "⚠ $sql_file may have already been applied or failed (non-fatal)"
      fi
    done
    
    echo "========================================"
    echo "PRE-MIGRATION SCRIPTS COMPLETE"
    echo "========================================"
    echo ""
  fi
fi

# Check if migrations directory exists and has migrations
MIGRATIONS_DIR="prisma/migrations"
if [ -d "$MIGRATIONS_DIR" ] && [ -n "$(find "$MIGRATIONS_DIR" -maxdepth 2 -type d -name '[0-9]*_*' 2>/dev/null)" ]; then
  echo "Found migration files in $MIGRATIONS_DIR"
  
  # Check if _prisma_migrations table exists (indicates migrations have been run before)
  if npx prisma migrate status 2>&1 | grep -q "Database schema is up to date"; then
    echo "✓ Database migrations are up to date"
  elif npx prisma migrate status 2>&1 | grep -q "Your database is not managed by Prisma Migrate"; then
    echo "⚠ Database exists but is not managed by Prisma Migrate"
    echo "This typically happens when switching from 'db push' to migrations"
    echo "Attempting to baseline and deploy migrations..."
    
    # Baseline the current state - mark all existing migrations as applied
    if npx prisma migrate resolve --applied "$(find "$MIGRATIONS_DIR" -maxdepth 2 -type d -name '[0-9]*_*' | head -n 1 | xargs basename)" 2>&1; then
      echo "✓ Database baselined successfully"
      
      # Now deploy any new migrations
      if npx prisma migrate deploy 2>&1; then
        echo "✓ New migrations deployed successfully"
      else
        echo "⚠ Migration deployment had issues, falling back to db push"
        if npx prisma db push 2>&1; then
          echo "✓ Database schema pushed successfully"
        else
          echo "✗ Failed to update database schema"
          exit 1
        fi
      fi
    else
      echo "⚠ Could not baseline migrations, using db push instead"
      if npx prisma db push 2>&1; then
        echo "✓ Database schema pushed successfully"
      else
        echo "✗ Failed to push database schema"
        exit 1
      fi
    fi
  else
    # Normal case: database is managed by Prisma Migrate, just deploy
    echo "Deploying migrations..."
    if npx prisma migrate deploy 2>&1; then
      echo "✓ Migrations deployed successfully"
    else
      echo "✗ Migration deployment failed, trying db push as fallback..."
      if npx prisma db push 2>&1; then
        echo "✓ Database schema pushed successfully"
      else
        echo "✗ Failed to push database schema"
        exit 1
      fi
    fi
  fi
else
  echo "No migration files found, using db push to create/update schema..."
  
  if npx prisma db push 2>&1; then
    echo "✓ Database schema created successfully"
  else
    echo "✗ Failed to create database schema"
    exit 1
  fi
fi

echo "========================================"
echo "DATABASE SETUP COMPLETE"
echo "========================================"

# Run any raw SQL migrations if they exist
if [ -d "prisma/migrations" ]; then
  SQL_FILES=$(find prisma/migrations -maxdepth 1 -name "*.sql" -type f 2>/dev/null | sort)
  if [ -n "$SQL_FILES" ]; then
    echo ""
    echo "========================================"
    echo "RUNNING RAW SQL MIGRATIONS"
    echo "========================================"
    
    for sql_file in $SQL_FILES; do
      echo "Running: $sql_file"
      if npx prisma db execute --file "$sql_file" 2>&1; then
        echo "✓ $sql_file executed successfully"
      else
        echo "⚠ $sql_file may have already been applied or failed (non-fatal)"
      fi
    done
    
    echo "========================================"
    echo "RAW SQL MIGRATIONS COMPLETE"
    echo "========================================"
  fi
fi

{% if busibox_env == 'test' or app_to_deploy.name == 'busibox-portal' %}
# Run database seeding
# - Always runs in test environment for all apps
# - Always runs for busibox-portal (creates core apps and role bindings)
if [ -f "package.json" ] && grep -q '"db:seed"' package.json; then
  echo ""
  echo "========================================"
{% if busibox_env == 'test' %}
  echo "SEEDING DATABASE (TEST ENVIRONMENT)"
{% else %}
  echo "SEEDING DATABASE ({{ app_to_deploy.name }})"
{% endif %}
  echo "========================================"
  
  if npm run db:seed 2>&1; then
    echo "✓ Database seeded successfully"
  else
    echo "⚠ Database seeding failed (non-fatal)"
    # Don't fail deployment if seeding fails
  fi
fi
{% endif %}


