#!/usr/bin/env bash
# Deploywatch Application Script: {{ app.name }}
# Auto-generated by Ansible - modifications will be overwritten
# Purpose: Monitor GitHub releases and deploy {{ app.github_repo }}
# Requirements: FR-001, FR-004, FR-035 (GitHub deployment, health checks, rollback)

set -euo pipefail

APP_NAME="{{ app.name }}"
GITHUB_REPO="{{ app.github_repo }}"
DEPLOY_PATH="{{ app.deploy_path }}"
HEALTH_ENDPOINT="{{ app.health_endpoint }}"
CONTAINER_IP="{{ app.container_ip }}"
PORT="{{ app.port }}"
PROCESS_MANAGER="{{ app.process_manager | default('pm2') }}"

VERSION_FILE="${DEPLOY_PATH}/.version"
BACKUP_DIR="${DEPLOY_PATH}.backup"
FAILED_DIR="${DEPLOY_PATH}.failed"
ENV_FILE="${DEPLOY_PATH}/.env"

# GitHub authentication (for private repos)
# Set GITHUB_TOKEN environment variable or create ~/.github_token file
if [[ -n "${GITHUB_TOKEN:-}" ]]; then
    CURL_AUTH_HEADER="Authorization: token ${GITHUB_TOKEN}"
elif [[ -f ~/.github_token ]]; then
    GITHUB_TOKEN=$(cat ~/.github_token)
    CURL_AUTH_HEADER="Authorization: token ${GITHUB_TOKEN}"
else
    CURL_AUTH_HEADER=""
fi

# Logging functions
log_info() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] [${APP_NAME}] INFO: $*" >&2
}

log_error() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] [${APP_NAME}] ERROR: $*" >&2
}

log_success() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] [${APP_NAME}] SUCCESS: $*" >&2
}

log_warn() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] [${APP_NAME}] WARNING: $*" >&2
}

# Get current deployed version
get_current_version() {
    if [[ -f "${VERSION_FILE}" ]]; then
        cat "${VERSION_FILE}"
    else
        echo "none"
    fi
}

# Get latest GitHub release
get_latest_release() {
    local release_info
    if [[ -n "${CURL_AUTH_HEADER}" ]]; then
        release_info=$(curl -s -H "${CURL_AUTH_HEADER}" "https://api.github.com/repos/${GITHUB_REPO}/releases/latest")
    else
        release_info=$(curl -s "https://api.github.com/repos/${GITHUB_REPO}/releases/latest")
    fi
    
    if echo "${release_info}" | jq -e '.tag_name' > /dev/null 2>&1; then
        echo "${release_info}" | jq -r '.tag_name'
    else
        # No releases found, use main branch
        log_info "No releases found, using main branch"
        echo "main"
    fi
}

# Health check function
check_health() {
    local max_attempts=30
    local attempt=1
    
    log_info "Running health check at http://${CONTAINER_IP}:${PORT}${HEALTH_ENDPOINT}"
    
    while [[ $attempt -le $max_attempts ]]; do
        # Try the health endpoint first
        if curl -sf "http://${CONTAINER_IP}:${PORT}${HEALTH_ENDPOINT}" > /dev/null 2>&1; then
            log_success "Health check passed (health endpoint responded)"
            return 0
        fi
        
        # If health endpoint fails, check if the port is at least listening
        if nc -z -w 1 "${CONTAINER_IP}" "${PORT}" 2>/dev/null; then
            # Port is listening, try root path as fallback
            if curl -sf --max-time 2 "http://${CONTAINER_IP}:${PORT}/" > /dev/null 2>&1; then
                log_success "Health check passed (root path responded, health endpoint may not exist)"
                return 0
            fi
        fi
        
        log_info "Health check attempt ${attempt}/${max_attempts} failed, retrying in 2s..."
        sleep 2
        ((attempt++))
    done
    
    # Final check: if port is listening at all, consider it a warning pass
    if nc -z -w 1 "${CONTAINER_IP}" "${PORT}" 2>/dev/null; then
        log_warn "Port ${PORT} is listening but health check failed - app may be starting"
        log_warn "Accepting deployment but verify manually"
        return 0
    fi
    
    log_error "Health check failed after ${max_attempts} attempts"
    log_error "Port ${PORT} is not listening - app failed to start"
    return 1
}

# Backup current deployment
backup_current() {
    if [[ -d "${DEPLOY_PATH}" ]]; then
        log_info "Backing up current deployment to ${BACKUP_DIR}"
        rm -rf "${BACKUP_DIR}"
        cp -a "${DEPLOY_PATH}" "${BACKUP_DIR}"
        log_success "Backup complete"
    else
        log_info "No existing deployment to backup"
    fi
}

# Rollback to previous version
rollback() {
    log_error "Rolling back to previous version"
    
    # Save failed deployment for debugging
    if [[ -d "${DEPLOY_PATH}" ]]; then
        local timestamp=$(date +'%Y%m%d-%H%M%S')
        local failed_backup="${FAILED_DIR}.${timestamp}"
        log_info "Saving failed deployment to ${failed_backup} for debugging"
        rm -rf "${failed_backup}"
        cp -a "${DEPLOY_PATH}" "${failed_backup}"
        log_info "Failed deployment saved - investigate with: ls -la ${failed_backup}"
    fi
    
    # Stop current version
    stop_application
    
    # Restore backup
    if [[ -d "${BACKUP_DIR}" ]]; then
        rm -rf "${DEPLOY_PATH}"
        mv "${BACKUP_DIR}" "${DEPLOY_PATH}"
        log_info "Previous version restored"
        
        # Ensure systemd service file exists
        create_systemd_service
        
        # Restart application
        start_application
        
        if check_health; then
            log_success "Rollback successful"
            # TODO: Send alert to operators (T081)
            return 0
        else
            log_error "Rollback failed - application not healthy"
            return 1
        fi
    else
        log_error "No backup available for rollback"
        return 1
    fi
}

# Download release from GitHub
download_release() {
    local version=$1
    local temp_dir=$(mktemp -d)
    
    # If version is "main", clone from git
    if [[ "${version}" == "main" ]]; then
        log_info "Cloning from main branch"
        mkdir -p "${temp_dir}/extracted"
        
        # Use token authentication for private repos
        local git_url
        if [[ -n "${GITHUB_TOKEN:-}" ]]; then
            git_url="https://${GITHUB_TOKEN}@github.com/${GITHUB_REPO}.git"
        else
            git_url="https://github.com/${GITHUB_REPO}.git"
        fi
        
        if git clone --depth 1 "${git_url}" "${temp_dir}/extracted/${GITHUB_REPO##*/}"; then
            log_success "Cloned repository successfully"
            echo "${temp_dir}"
            return 0
        else
            log_error "Failed to clone repository"
            rm -rf "${temp_dir}"
            return 1
        fi
    fi
    
    # Try to get release assets first (uploaded tarballs)
    log_info "Checking for release assets for ${version}"
    local release_info
    if [[ -n "${CURL_AUTH_HEADER}" ]]; then
        release_info=$(curl -s -H "${CURL_AUTH_HEADER}" "https://api.github.com/repos/${GITHUB_REPO}/releases/tags/${version}")
    else
        release_info=$(curl -s "https://api.github.com/repos/${GITHUB_REPO}/releases/tags/${version}")
    fi
    local asset_url=$(echo "${release_info}" | jq -r '.assets[] | select(.name | test("\\.tar\\.gz$")) | .browser_download_url' | head -1)
    
    if [[ -n "${asset_url}" && "${asset_url}" != "null" ]]; then
        # Use uploaded release asset
        log_info "Downloading release asset from ${asset_url}"
        local curl_cmd="curl -L -o ${temp_dir}/release.tar.gz"
        [[ -n "${CURL_AUTH_HEADER}" ]] && curl_cmd="${curl_cmd} -H '${CURL_AUTH_HEADER}'"
        curl_cmd="${curl_cmd} ${asset_url}"
        
        if eval "${curl_cmd}"; then
            log_success "Downloaded release asset"
            echo "${temp_dir}"
            return 0
        else
            log_error "Failed to download release asset"
        fi
    fi
    
    # Fall back to source archive via API (supports authentication)
    log_info "Downloading source archive via GitHub API"
    
    # Use GitHub API tarball_url which supports authentication
    local tarball_url
    if [[ -n "${CURL_AUTH_HEADER}" ]]; then
        tarball_url=$(curl -s -H "${CURL_AUTH_HEADER}" "https://api.github.com/repos/${GITHUB_REPO}/releases/tags/${version}" | jq -r '.tarball_url')
    else
        tarball_url=$(curl -s "https://api.github.com/repos/${GITHUB_REPO}/releases/tags/${version}" | jq -r '.tarball_url')
    fi
    
    # If tarball_url is available from release API, use it
    if [[ -n "${tarball_url}" && "${tarball_url}" != "null" ]]; then
        log_info "Using API tarball URL: ${tarball_url}"
        if [[ -n "${CURL_AUTH_HEADER}" ]]; then
            if curl -L -H "${CURL_AUTH_HEADER}" -o "${temp_dir}/release.tar.gz" "${tarball_url}"; then
                log_success "Downloaded source archive via API"
                echo "${temp_dir}"
                return 0
            fi
        else
            if curl -L -o "${temp_dir}/release.tar.gz" "${tarball_url}"; then
                log_success "Downloaded source archive"
                echo "${temp_dir}"
                return 0
            fi
        fi
    fi
    
    # Final fallback: try direct archive URL with token in URL (for private repos)
    local archive_url="https://github.com/${GITHUB_REPO}/archive/refs/tags/${version}.tar.gz"
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        # Add token as URL parameter for private repos (GitHub archive URLs don't support Auth header)
        archive_url="https://${GITHUB_TOKEN}@github.com/${GITHUB_REPO}/archive/refs/tags/${version}.tar.gz"
        log_info "Downloading source archive with authentication"
    else
        log_info "Downloading public source archive from ${archive_url}"
    fi
    
    if curl -L -o "${temp_dir}/release.tar.gz" "${archive_url}"; then
        log_success "Downloaded source archive"
        echo "${temp_dir}"
        return 0
    else
        log_error "Failed to download release"
        rm -rf "${temp_dir}"
        return 1
    fi
}

# Deploy application
deploy_application() {
    local version=$1
    local temp_dir=$2
    
    log_info "Deploying ${version} to ${DEPLOY_PATH}"
    
    # Extract tarball if it exists (not needed for git clone)
    if [[ -f "${temp_dir}/release.tar.gz" ]]; then
        mkdir -p "${temp_dir}/extracted"
        tar -xzf "${temp_dir}/release.tar.gz" -C "${temp_dir}/extracted"
    fi
    
    # Find extracted directory (GitHub archives as owner-repo-version/)
    # GitHub creates a subdirectory like "agent-server-0.0.1/" or "agent-server-v0.0.1/"
    # For git clones, it's just the repo name
    local extracted_dir=$(find "${temp_dir}/extracted" -mindepth 1 -maxdepth 1 -type d | head -1)
    
    if [[ -z "${extracted_dir}" ]]; then
        log_error "Could not find extracted directory in ${temp_dir}/extracted"
        ls -la "${temp_dir}/extracted" >&2
        return 1
    fi
    
    log_info "Found extracted directory: ${extracted_dir}"
    
    # Create deploy path if it doesn't exist
    mkdir -p "${DEPLOY_PATH}"
    
    # Copy files to deploy path (using cp -a instead of rsync for portability)
    # Remove existing files first (except .env)
    find "${DEPLOY_PATH}" -mindepth 1 ! -name '.env' ! -name '.version' -exec rm -rf {} + 2>/dev/null || true
    
    # Copy new files
    cp -a "${extracted_dir}/." "${DEPLOY_PATH}/"
    
    # Restore .env file if it was backed up
    if [[ -f "${BACKUP_DIR}/.env" ]]; then
        cp "${BACKUP_DIR}/.env" "${ENV_FILE}"
    fi
    
    # Update version file
    echo "${version}" > "${VERSION_FILE}"
    
    log_success "Deployment complete"
}

# Install dependencies
install_dependencies() {
    cd "${DEPLOY_PATH}"
    
    # Export GitHub token for npm authentication to GitHub Packages
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        export GITHUB_TOKEN
        log_info "GitHub token available for npm authentication"
    fi
    
    # Create .npmrc for GitHub Packages authentication (if package.json exists)
    if [[ -f "package.json" ]]; then
        log_info "Creating .npmrc for GitHub Packages authentication"
        cat > .npmrc << 'EOF'
@jazzmind:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
EOF
    fi
    
    # Node.js application
    if [[ -f "package.json" ]]; then
        log_info "Installing Node.js dependencies"
        
        # Check if we need devDependencies (for migrations, builds, etc.)
        local needs_dev=false
        if grep -q '"migrate:up"' package.json || \
           grep -q '"build"' package.json || \
           grep -q '"mastra"' package.json; then
            needs_dev=true
        fi
        
        if [[ "$needs_dev" == "true" ]]; then
            log_info "Installing all dependencies (including dev) for migrations/build"
            if npm install 2>&1 | sed 's/^/[npm] /' >&2; then
                log_success "Dependencies installed successfully"
                return 0
            else
                log_error "Failed to install dependencies"
                return 1
            fi
        else
            log_info "Installing production dependencies only"
            if npm install --production 2>&1 | sed 's/^/[npm] /' >&2; then
                log_success "Dependencies installed successfully"
                return 0
            else
                log_error "Failed to install dependencies"
                return 1
            fi
        fi
    fi
    
    # Python application
    if [[ -f "requirements.txt" ]]; then
        log_info "Installing Python dependencies"
        if pip3 install -r requirements.txt 2>&1 | sed 's/^/[pip] /' >&2; then
            log_success "Dependencies installed successfully"
            return 0
        else
            log_error "Failed to install dependencies"
            return 1
        fi
    fi
    
    log_info "No dependencies to install"
    return 0
}

# Run database migrations (if present)
run_migrations() {
    cd "${DEPLOY_PATH}"
    
    # Load environment variables from .env file if it exists
    if [[ -f ".env" ]]; then
        log_info "Loading environment variables from .env"
        set -a  # Automatically export all variables
        source .env
        set +a  # Turn off automatic export
    fi
    
    # Check for npm migration script first
    if [[ -f "package.json" ]] && grep -q '"migrate:up"' package.json; then
        log_info "Running database migrations via npm"
        if npm run migrate:up 2>&1 | sed 's/^/[migration] /' >&2; then
            log_success "Migrations completed successfully"
            return 0
        else
            log_error "Migration failed"
            return 1
        fi
    fi
    
    # Check for shell script
    local migration_script="scripts/migrate.sh"
    if [[ -f "${migration_script}" && -x "${migration_script}" ]]; then
        log_info "Running database migrations via script"
        if bash "${migration_script}"; then
            log_success "Migrations completed successfully"
            return 0
        else
            log_error "Migration failed"
            return 1
        fi
    fi
    
    log_info "No migrations to run"
    return 0
}

# Build application (if build command specified)
build_application() {
    cd "${DEPLOY_PATH}"
    
    # Load environment variables from .env file if it exists
    if [[ -f ".env" ]]; then
        set -a  # Automatically export all variables
        source .env
        set +a  # Turn off automatic export
    fi
    
{% if app.build_command is defined %}
    log_info "Running build command: {{ app.build_command }}"
    if {{ app.build_command }}; then
        log_success "Build completed successfully"
        return 0
    else
        log_error "Build failed"
        return 1
    fi
{% else %}
    # Auto-detect build script
    if [[ -f "package.json" ]] && grep -q '"build"' package.json; then
        log_info "Running npm build (build script detected in package.json)"
        if npm run build 2>&1 | sed 's/^/[build] /' >&2; then
            log_success "Build completed successfully"
            return 0
        else
            log_error "Build failed"
            return 1
        fi
    else
        log_info "No build command specified, skipping build"
        return 0
    fi
{% endif %}
}

# Create systemd service file if using systemd
create_systemd_service() {
    if [[ "${PROCESS_MANAGER}" != "systemd" ]]; then
        return 0
    fi
    
    local service_file="/etc/systemd/system/${APP_NAME}.service"
    
    log_info "Creating/updating systemd service file: ${service_file}"
    
    cat > "${service_file}" << 'SERVICEEOF'
# Systemd service for {{ app.name }}
# Generated by deploywatch

[Unit]
Description={{ app.name }} Application
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory={{ app.deploy_path }}

# Environment variables
{% if app.env is defined %}
{% for key, value in app.env.items() %}
Environment="{{ key }}={{ value }}"
{% endfor %}
{% endif %}

# Port configuration
Environment="PORT={{ app.port }}"
Environment="NODE_ENV=production"

# Start command
{% if app.start_command is defined %}
ExecStart=/bin/bash -c '{{ app.start_command }}'
{% else %}
ExecStart=/usr/bin/npm start -- -p {{ app.port }}
{% endif %}

# Restart configuration
Restart=always
RestartSec=10
StartLimitIntervalSec=60
StartLimitBurst=3

# Logging - use journal for consistent timestamps
StandardOutput=journal
StandardError=journal
SyslogIdentifier={{ app.name }}

[Install]
WantedBy=multi-user.target
SERVICEEOF

    # Reload systemd to pick up the new/updated service
    systemctl daemon-reload
    
    # Enable the service to start on boot
    systemctl enable "${APP_NAME}.service" 2>/dev/null || true
    
    log_success "Systemd service file created/updated"
}

# Stop application
stop_application() {
    if [[ "${PROCESS_MANAGER}" == "pm2" ]]; then
        log_info "Stopping application via PM2"
        # Stop and delete all instances of this app (including old stopped ones)
        pm2 delete "${APP_NAME}" 2>/dev/null || true
        # Wait for cleanup
        sleep 1
    elif [[ "${PROCESS_MANAGER}" == "systemd" ]]; then
        log_info "Stopping application via systemd"
        systemctl stop "${APP_NAME}.service" 2>/dev/null || true
    fi
}

# Start application
start_application() {
    cd "${DEPLOY_PATH}"
    
    if [[ "${PROCESS_MANAGER}" == "pm2" ]]; then
        log_info "Starting application via PM2"
{% if app.start_command is defined %}
        # Use custom start command
        pm2 start "{{ app.start_command }}" --name "${APP_NAME}"
{% else %}
        # Auto-detect: package.json (Node.js) or main.py (Python)
        if [[ -f "package.json" ]]; then
            log_info "Detected Node.js application (package.json found)"
            
            # Debug: Show .mastra directory structure
            if [[ -d ".mastra" ]]; then
                log_info "Contents of .mastra directory:"
                ls -la .mastra/ >&2 || true
                if [[ -d ".mastra/.build" ]]; then
                    log_info "Contents of .mastra/.build directory:"
                    ls -la .mastra/.build/ >&2 || true
                fi
            fi
            
            # Check if this is a Mastra app (built output in .mastra/output or .mastra/.build)
            MASTRA_BUILD_DIR=""
            if [[ -d ".mastra/output" ]]; then
                MASTRA_BUILD_DIR=".mastra/output"
                log_info "Found Mastra build at: .mastra/output"
            elif [[ -d ".mastra/.build" ]]; then
                MASTRA_BUILD_DIR=".mastra/.build"
                log_info "Found Mastra build at: .mastra/.build"
            fi
            
            if [[ -n "$MASTRA_BUILD_DIR" ]]; then
                log_info "Mastra app detected, build found at: $MASTRA_BUILD_DIR"
                
                # Mastra apps are started with 'npm start' which runs 'mastra start'
                # The build output in .mastra/.build is used by the mastra CLI
                # mastra is a devDependency installed in node_modules
                log_info "Starting Mastra app with: npm start"
                
                # Verify mastra is available
                if [[ -f "node_modules/.bin/mastra" ]]; then
                    log_info "✓ mastra CLI found in node_modules/.bin/"
                else
                    log_error "✗ mastra CLI not found - check if devDependencies were installed"
                    ls -la node_modules/.bin/ >&2 || true
                fi
                
                pm2 start npm --name "${APP_NAME}" -- start
            # Check if this has a start script
            elif grep -q '"start"' package.json; then
                log_info "Using npm start (npm script detected)"
                pm2 start npm --name "${APP_NAME}" -- start
            else
                # Try to use package.json directly (works for some apps)
                pm2 start package.json --name "${APP_NAME}"
            fi
        elif [[ -f "main.py" ]]; then
            log_info "Detected Python application (main.py found)"
            pm2 start main.py --name "${APP_NAME}" --interpreter python3 || pm2 restart "${APP_NAME}"
        elif [[ -f "app.py" ]]; then
            log_info "Detected Python application (app.py found)"
            pm2 start app.py --name "${APP_NAME}" --interpreter python3 || pm2 restart "${APP_NAME}"
        elif [[ -f "server.js" ]]; then
            log_info "Detected Node.js application (server.js found)"
            pm2 start server.js --name "${APP_NAME}" || pm2 restart "${APP_NAME}"
        elif [[ -f "index.js" ]]; then
            log_info "Detected Node.js application (index.js found)"
            pm2 start index.js --name "${APP_NAME}" || pm2 restart "${APP_NAME}"
        else
            log_error "Could not detect application entry point"
            log_error "Files in ${DEPLOY_PATH}:"
            ls -la "${DEPLOY_PATH}" >&2
            return 1
        fi
{% endif %}
    elif [[ "${PROCESS_MANAGER}" == "systemd" ]]; then
        log_info "Starting application via systemd"
        systemctl start "${APP_NAME}.service"
    fi
}

# Main deployment flow
main() {
    log_info "Checking for new release"
    
    local current_version=$(get_current_version)
    log_info "Current version: ${current_version}"
    
    local latest_version=$(get_latest_release)
    if [[ $? -ne 0 ]]; then
        log_error "Failed to check for updates"
        return 1
    fi
    
    log_info "Latest version: ${latest_version}"
    
    if [[ "${current_version}" == "${latest_version}" ]]; then
        log_info "Already on latest version, no update needed"
        return 0
    fi
    
    log_info "New version available: ${latest_version}"
    
    # Backup current deployment
    backup_current
    
    # Download new release
    local temp_dir=$(download_release "${latest_version}")
    if [[ $? -ne 0 ]]; then
        log_error "Download failed, aborting"
        return 1
    fi
    
    # Deploy application
    if ! deploy_application "${latest_version}" "${temp_dir}"; then
        log_error "Deployment failed"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
    
    # Install dependencies
    if ! install_dependencies; then
        log_error "Dependency installation failed, rolling back"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
    
    # Run migrations (FR-036)
    if ! run_migrations; then
        log_error "Migrations failed, rolling back"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
    
    # Build application
    if ! build_application; then
        log_error "Build failed, rolling back"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
    
    # Stop old version
    stop_application
    
    # Create/update systemd service file if using systemd
    create_systemd_service
    
    # Start new version
    start_application
    
    # Health check (FR-004)
    if check_health; then
        log_success "Deployment successful: ${latest_version}"
        rm -rf "${temp_dir}"
        return 0
    else
        log_error "Health check failed, rolling back"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
}

# Run main deployment
main

