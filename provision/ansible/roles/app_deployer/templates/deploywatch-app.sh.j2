#!/usr/bin/env bash
# Deploywatch Application Script: {{ app.name }}
# Auto-generated by Ansible - modifications will be overwritten
# Purpose: Monitor GitHub releases and deploy {{ app.github_repo }}
# Requirements: FR-001, FR-004, FR-035 (GitHub deployment, health checks, rollback)

set -euo pipefail

APP_NAME="{{ app.name }}"
GITHUB_REPO="{{ app.github_repo }}"
DEPLOY_PATH="{{ app.deploy_path }}"
HEALTH_ENDPOINT="{{ app.health_endpoint }}"
CONTAINER_IP="{{ app.container_ip }}"
PORT="{{ app.port }}"
PROCESS_MANAGER="{{ app.process_manager | default('pm2') }}"

VERSION_FILE="${DEPLOY_PATH}/.version"
BACKUP_DIR="${DEPLOY_PATH}.backup"
ENV_FILE="${DEPLOY_PATH}/.env"

# Logging functions
log_info() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] [${APP_NAME}] INFO: $*"
}

log_error() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] [${APP_NAME}] ERROR: $*" >&2
}

log_success() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] [${APP_NAME}] SUCCESS: $*"
}

# Get current deployed version
get_current_version() {
    if [[ -f "${VERSION_FILE}" ]]; then
        cat "${VERSION_FILE}"
    else
        echo "none"
    fi
}

# Get latest GitHub release
get_latest_release() {
    local release_info
    release_info=$(curl -s "https://api.github.com/repos/${GITHUB_REPO}/releases/latest")
    
    if echo "${release_info}" | jq -e '.tag_name' > /dev/null 2>&1; then
        echo "${release_info}" | jq -r '.tag_name'
    else
        log_error "Failed to fetch latest release from GitHub"
        return 1
    fi
}

# Health check function
check_health() {
    local max_attempts=30
    local attempt=1
    
    log_info "Running health check at http://${CONTAINER_IP}:${PORT}${HEALTH_ENDPOINT}"
    
    while [[ $attempt -le $max_attempts ]]; do
        if curl -sf "http://${CONTAINER_IP}:${PORT}${HEALTH_ENDPOINT}" > /dev/null 2>&1; then
            log_success "Health check passed"
            return 0
        fi
        
        log_info "Health check attempt ${attempt}/${max_attempts} failed, retrying in 2s..."
        sleep 2
        ((attempt++))
    done
    
    log_error "Health check failed after ${max_attempts} attempts"
    return 1
}

# Backup current deployment
backup_current() {
    if [[ -d "${DEPLOY_PATH}" ]]; then
        log_info "Backing up current deployment to ${BACKUP_DIR}"
        rm -rf "${BACKUP_DIR}"
        cp -a "${DEPLOY_PATH}" "${BACKUP_DIR}"
        log_success "Backup complete"
    else
        log_info "No existing deployment to backup"
    fi
}

# Rollback to previous version
rollback() {
    log_error "Rolling back to previous version"
    
    # Stop current version
    stop_application
    
    # Restore backup
    if [[ -d "${BACKUP_DIR}" ]]; then
        rm -rf "${DEPLOY_PATH}"
        mv "${BACKUP_DIR}" "${DEPLOY_PATH}"
        log_info "Previous version restored"
        
        # Restart application
        start_application
        
        if check_health; then
            log_success "Rollback successful"
            # TODO: Send alert to operators (T081)
            return 0
        else
            log_error "Rollback failed - application not healthy"
            return 1
        fi
    else
        log_error "No backup available for rollback"
        return 1
    fi
}

# Download release from GitHub
download_release() {
    local version=$1
    local tarball_url="https://github.com/${GITHUB_REPO}/archive/refs/tags/${version}.tar.gz"
    local temp_dir=$(mktemp -d)
    
    log_info "Downloading release ${version} from ${tarball_url}"
    
    if curl -L -o "${temp_dir}/release.tar.gz" "${tarball_url}"; then
        log_success "Download complete"
        echo "${temp_dir}"
    else
        log_error "Failed to download release"
        rm -rf "${temp_dir}"
        return 1
    fi
}

# Deploy application
deploy_application() {
    local version=$1
    local temp_dir=$2
    
    log_info "Deploying ${version} to ${DEPLOY_PATH}"
    
    # Extract tarball
    mkdir -p "${DEPLOY_PATH}"
    tar -xzf "${temp_dir}/release.tar.gz" -C "${temp_dir}"
    
    # Find extracted directory (GitHub archives as owner-repo-version/)
    local extracted_dir=$(find "${temp_dir}" -maxdepth 1 -type d -name "*-*" | head -1)
    
    if [[ -z "${extracted_dir}" ]]; then
        log_error "Could not find extracted directory"
        return 1
    fi
    
    # Copy files to deploy path
    rsync -a "${extracted_dir}/" "${DEPLOY_PATH}/"
    
    # Restore .env file if it was backed up
    if [[ -f "${BACKUP_DIR}/.env" ]]; then
        cp "${BACKUP_DIR}/.env" "${ENV_FILE}"
    fi
    
    # Update version file
    echo "${version}" > "${VERSION_FILE}"
    
    log_success "Deployment complete"
}

# Run database migrations (if present)
run_migrations() {
    local migration_script="${DEPLOY_PATH}/scripts/migrate.sh"
    
    if [[ -f "${migration_script}" && -x "${migration_script}" ]]; then
        log_info "Running database migrations"
        
        if bash "${migration_script}"; then
            log_success "Migrations completed successfully"
            return 0
        else
            log_error "Migration failed"
            return 1
        fi
    else
        log_info "No migrations to run"
        return 0
    fi
}

# Build application (if build command specified)
build_application() {
{% if app.build_command is defined %}
    log_info "Running build command: {{ app.build_command }}"
    cd "${DEPLOY_PATH}"
    
    if {{ app.build_command }}; then
        log_success "Build completed successfully"
        return 0
    else
        log_error "Build failed"
        return 1
    fi
{% else %}
    log_info "No build command specified, skipping build"
    return 0
{% endif %}
}

# Stop application
stop_application() {
    if [[ "${PROCESS_MANAGER}" == "pm2" ]]; then
        log_info "Stopping application via PM2"
        pm2 stop "${APP_NAME}" || true
    elif [[ "${PROCESS_MANAGER}" == "systemd" ]]; then
        log_info "Stopping application via systemd"
        systemctl stop "${APP_NAME}.service" || true
    fi
}

# Start application
start_application() {
    cd "${DEPLOY_PATH}"
    
    if [[ "${PROCESS_MANAGER}" == "pm2" ]]; then
        log_info "Starting application via PM2"
{% if app.start_command is defined %}
        pm2 start "{{ app.start_command }}" --name "${APP_NAME}" || pm2 restart "${APP_NAME}"
{% else %}
        pm2 start package.json --name "${APP_NAME}" || pm2 restart "${APP_NAME}"
{% endif %}
    elif [[ "${PROCESS_MANAGER}" == "systemd" ]]; then
        log_info "Starting application via systemd"
        systemctl start "${APP_NAME}.service"
    fi
}

# Main deployment flow
main() {
    log_info "Checking for new release"
    
    local current_version=$(get_current_version)
    log_info "Current version: ${current_version}"
    
    local latest_version=$(get_latest_release)
    if [[ $? -ne 0 ]]; then
        log_error "Failed to check for updates"
        return 1
    fi
    
    log_info "Latest version: ${latest_version}"
    
    if [[ "${current_version}" == "${latest_version}" ]]; then
        log_info "Already on latest version, no update needed"
        return 0
    fi
    
    log_info "New version available: ${latest_version}"
    
    # Backup current deployment
    backup_current
    
    # Download new release
    local temp_dir=$(download_release "${latest_version}")
    if [[ $? -ne 0 ]]; then
        log_error "Download failed, aborting"
        return 1
    fi
    
    # Deploy application
    if ! deploy_application "${latest_version}" "${temp_dir}"; then
        log_error "Deployment failed"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
    
    # Run migrations (FR-036)
    if ! run_migrations; then
        log_error "Migrations failed, rolling back"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
    
    # Build application
    if ! build_application; then
        log_error "Build failed, rolling back"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
    
    # Stop old version
    stop_application
    
    # Start new version
    start_application
    
    # Health check (FR-004)
    if check_health; then
        log_success "Deployment successful: ${latest_version}"
        rm -rf "${temp_dir}"
        return 0
    else
        log_error "Health check failed, rolling back"
        rm -rf "${temp_dir}"
        rollback
        return 1
    fi
}

# Run main deployment
main

