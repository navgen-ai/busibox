# Busibox Docker Environment Configuration
# Generated by Ansible - {{ ansible_date_time.iso8601 }}
# Do not edit manually - changes will be overwritten
#
# Secrets are sourced from busibox_secrets (shared_secrets.yml).
# To modify, update the Ansible variables and re-run deployment.

# =============================================================================
# Container Configuration
# =============================================================================
CONTAINER_PREFIX={{ container_prefix }}
COMPOSE_PROJECT_NAME={{ compose_project_name }}

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_PASSWORD={{ busibox_secrets.POSTGRES_PASSWORD }}
POSTGRES_USER={{ busibox_secrets.POSTGRES_USER }}
POSTGRES_DB={{ postgres_db | default('busibox') }}

# =============================================================================
# MinIO Configuration
# =============================================================================
MINIO_ROOT_USER={{ busibox_secrets.MINIO_ROOT_USER }}
MINIO_ROOT_PASSWORD={{ busibox_secrets.MINIO_ROOT_PASSWORD }}
MINIO_ACCESS_KEY={{ busibox_secrets.MINIO_ROOT_USER }}
MINIO_SECRET_KEY={{ busibox_secrets.MINIO_ROOT_PASSWORD }}

# =============================================================================
# Authentication
# =============================================================================
AUTHZ_MASTER_KEY={{ busibox_secrets.AUTHZ_MASTER_KEY }}
SSO_JWT_SECRET={{ busibox_secrets.SSO_JWT_SECRET }}
SESSION_SECRET={{ busibox_secrets.SESSION_SECRET }}

# =============================================================================
# LiteLLM Configuration
# =============================================================================
LITELLM_MASTER_KEY={{ busibox_secrets.LITELLM_MASTER_KEY }}
LITELLM_API_KEY={{ busibox_secrets.LITELLM_MASTER_KEY }}
LITELLM_SALT_KEY={{ busibox_secrets.LITELLM_SALT_KEY }}

# =============================================================================
# Neo4j Configuration
# =============================================================================
NEO4J_PASSWORD={{ busibox_secrets.NEO4J_PASSWORD }}

# =============================================================================
# Config API Encryption
# =============================================================================
CONFIG_ENCRYPTION_KEY={{ busibox_secrets.CONFIG_ENCRYPTION_KEY }}

# =============================================================================
# GitHub Configuration
# =============================================================================
GITHUB_AUTH_TOKEN={{ busibox_secrets.GITHUB_AUTH_TOKEN }}

# =============================================================================
# Admin Configuration
# =============================================================================
ADMIN_EMAILS={{ busibox_secrets.ADMIN_EMAILS }}
ALLOWED_EMAIL_DOMAINS={{ busibox_secrets.ALLOWED_EMAIL_DOMAINS }}

# =============================================================================
# Domain Configuration
# =============================================================================
BASE_DOMAIN={{ base_domain | default('localhost') }}

# =============================================================================
# Core Apps - which apps to build/start (comma-separated, or "all")
# =============================================================================
ENABLED_APPS={{ enabled_apps | default('portal,admin') }}

# =============================================================================
# External API Keys (if configured)
# =============================================================================
{% if busibox_secrets.OPENAI_API_KEY | default('') | length > 0 %}
OPENAI_API_KEY={{ busibox_secrets.OPENAI_API_KEY }}
{% endif %}
{% if huggingface_token | default('') | length > 0 %}
HUGGINGFACE_TOKEN={{ huggingface_token }}
{% endif %}

# =============================================================================
# Development Paths (for volume mounts)
# =============================================================================
{% if busibox_frontend_dir | default('') | length > 0 %}
BUSIBOX_FRONTEND_DIR={{ busibox_frontend_dir }}
{% endif %}
{% if busibox_app_dir | default('') | length > 0 %}
BUSIBOX_APP_DIR={{ busibox_app_dir }}
{% endif %}
BUSIBOX_HOST_PATH={{ docker_compose_dir }}

# =============================================================================
# Feature Flags
# =============================================================================
LLM_BACKEND={{ lookup('env', 'LLM_BACKEND') | default('', true) }}
LLM_TIER={{ lookup('env', 'LLM_TIER') | default('', true) }}
LLM_CLEANUP_ENABLED={{ llm_cleanup_enabled | default(false) | lower }}
MARKER_ENABLED={{ marker_enabled | default(false) | lower }}
COLPALI_ENABLED={{ colpali_enabled | default(false) | lower }}

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL={{ log_level | default('debug') }}
NODE_ENV={{ node_env | default('development') }}
