# Deploy API Environment Configuration
# Generated by Ansible - do not edit manually

# Service Configuration
DEPLOY_PORT={{ deploy_api_service_port }}
DEBUG={{ deploy_api_debug | lower }}

# Deployment backend: "docker" or "proxmox"
# Explicitly set so the deploy-api knows how to manage services
DEPLOYMENT_BACKEND=proxmox

# Environment (staging or production)
# Used for selecting the correct Ansible inventory
ENVIRONMENT={{ deployment_environment | default('staging') }}
BUSIBOX_ENV={{ busibox_env | default(deployment_environment | default('staging')) }}

# LLM Backend: "vllm", "mlx", or "cloud"
# On Proxmox with GPUs, this is typically "vllm"
# Set explicitly so platform detection works correctly
LLM_BACKEND={{ llm_backend | default('vllm') }}

# Whether staging uses production vLLM instead of deploying its own
# When true, staging verifies production vLLM health instead of installing
USE_PRODUCTION_VLLM={{ use_production_vllm | default(false) | lower }}

# Bootstrap Token for initial Ansible provisioning
# This allows Ansible to deploy apps without a real user JWT
DEPLOY_BOOTSTRAP_TOKEN={{ deploy_api_bootstrap_token }}

# Authz Service (for token validation)
AUTHZ_URL={{ deploy_api_authz_url }}

# Ansible Configuration
ANSIBLE_DIR={{ deploy_api_ansible_dir }}

# Busibox state file (for tracking installation state)
BUSIBOX_STATE_FILE=/root/busibox/.busibox-state

# PostgreSQL (for database provisioning)
POSTGRES_HOST={{ deploy_api_postgres_host }}
POSTGRES_PORT={{ deploy_api_postgres_port }}
POSTGRES_ADMIN_USER={{ deploy_api_postgres_admin_user }}
POSTGRES_ADMIN_PASSWORD={{ deploy_api_postgres_admin_password }}

# Container IPs
APPS_CONTAINER_IP={{ deploy_api_apps_container_ip }}
APPS_CONTAINER_IP_STAGING={{ deploy_api_apps_container_ip_staging }}

# SSH Key Path
SSH_KEY_PATH={{ deploy_api_ssh_key_path }}

# Proxmox Host (for running make install commands)
# deploy-api SSHes to the Proxmox host to run Ansible playbooks
# The Proxmox host has the vault and vault password files
PROXMOX_HOST={{ deploy_api_proxmox_host }}

# Nginx Configuration
NGINX_HOST={{ deploy_api_nginx_host }}
NGINX_CONFIG_DIR={{ deploy_api_nginx_config_dir }}
NGINX_ENABLED_DIR={{ deploy_api_nginx_enabled_dir }}

# Rate Limiting
RATE_LIMIT_MINUTES={{ deploy_api_rate_limit_minutes }}
