#!/usr/bin/env python3
"""
ColPali API Server
Provides OpenAI-compatible embeddings API for ColPali vision model
"""

import os
import sys
from typing import List, Optional
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
import torch
from PIL import Image
import io
import base64

# Set up paths
os.environ['HF_HOME'] = '{{ vllm_colpali_cache_dir }}'
os.environ['TRANSFORMERS_CACHE'] = '{{ vllm_colpali_cache_dir }}'

try:
    from colpali_engine.models import ColPali, ColPaliProcessor
except ImportError:
    print("ERROR: colpali-engine not installed. Install with: pip install colpali-engine", file=sys.stderr)
    sys.exit(1)

app = FastAPI(title="ColPali API", version="1.0")

# Global model and processor
model = None
processor = None

class EmbeddingRequest(BaseModel):
    model: str
    input: str | List[str]  # Base64 encoded images or image URLs

class EmbeddingResponse(BaseModel):
    object: str = "list"
    data: List[dict]
    model: str
    usage: dict

@app.on_event("startup")
async def load_model():
    global model, processor
    
    model_name = "{{ vllm_colpali_model }}"
    device = "cuda:{{ vllm_colpali_cuda_visible_devices }}"
    
    print(f"Loading ColPali model: {model_name}")
    print(f"Device: {device}")
    
    try:
        model = ColPali.from_pretrained(
            model_name,
            torch_dtype=torch.bfloat16,
            device_map=device,
        ).eval()
        
        processor = ColPaliProcessor.from_pretrained(model_name)
        
        print(f"Model loaded successfully on {device}")
    except Exception as e:
        print(f"ERROR loading model: {e}", file=sys.stderr)
        sys.exit(1)

@app.get("/health")
async def health():
    return {"status": "ok", "model_loaded": model is not None}

@app.get("/v1/models")
async def list_models():
    return {
        "object": "list",
        "data": [
            {
                "id": "{{ vllm_colpali_served_model_name }}",
                "object": "model",
                "created": 1234567890,
                "owned_by": "vidore"
            }
        ]
    }

@app.post("/v1/embeddings")
async def create_embeddings(request: EmbeddingRequest):
    if model is None or processor is None:
        raise HTTPException(status_code=503, detail="Model not loaded")
    
    # Handle input
    inputs = request.input if isinstance(request.input, list) else [request.input]
    
    # Decode base64 images
    images = []
    for inp in inputs:
        try:
            # Assume base64 encoded image
            if inp.startswith('data:image'):
                # Remove data URL prefix
                inp = inp.split(',', 1)[1]
            
            image_data = base64.b64decode(inp)
            image = Image.open(io.BytesIO(image_data))
            images.append(image)
        except Exception as e:
            raise HTTPException(status_code=400, detail=f"Invalid image data: {e}")
    
    # Process images
    try:
        batch_images = processor.process_images(images).to(model.device)
        
        with torch.no_grad():
            image_embeddings = model(**batch_images)
        
        # Convert to list format
        embeddings_list = []
        for i, emb in enumerate(image_embeddings):
            # ColPali outputs multi-vector embeddings (128 patches x 128 dims)
            # Flatten to single vector for OpenAI compatibility
            flat_emb = emb.cpu().flatten().tolist()
            
            embeddings_list.append({
                "object": "embedding",
                "embedding": flat_emb,
                "index": i
            })
        
        return EmbeddingResponse(
            data=embeddings_list,
            model=request.model,
            usage={
                "prompt_tokens": len(inputs),
                "total_tokens": len(inputs)
            }
        )
    
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Embedding generation failed: {e}")

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(
        app,
        host="{{ vllm_colpali_host }}",
        port={{ vllm_colpali_port }},
        log_level="info"
    )

