# Ollama Environment Configuration
# Auto-generated by Ansible - modifications will be overwritten

# Network Configuration
OLLAMA_HOST={{ ollama_host }}:{{ ollama_port }}

# Model Storage
OLLAMA_MODELS={{ ollama_models_dir }}

# Performance Configuration
OLLAMA_NUM_PARALLEL={{ ollama_num_parallel }}
OLLAMA_MAX_LOADED_MODELS={{ ollama_max_loaded_models }}
OLLAMA_MAX_QUEUE={{ ollama_max_queue }}

# GPU Configuration
{% if ollama_has_gpu | default(false) and ollama_gpu_enabled %}
# GPU acceleration enabled
OLLAMA_GPU_LAYERS={{ ollama_gpu_layers }}
{% else %}
# CPU-only mode
OLLAMA_GPU_LAYERS=0
{% endif %}

# Logging
OLLAMA_LOG_LEVEL={{ ollama_log_level }}

# Additional environment variables can be added here

