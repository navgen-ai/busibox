# Main Domain Virtual Host: {{ domain }}
# Auto-generated by Ansible - modifications will be overwritten
# Handles domain and path-based routing

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    
    # Server names from all domain-type routes
    server_name {% for app in apps_with_routes %}{% for route in app.routes %}{% if route.type == 'domain' %}{% for d in route.domains %}{{ d }} {% endfor %}{% endif %}{% endfor %}{% endfor %}{{ domain }};
    
    # SSL Configuration
    ssl_certificate {{ ssl_certificate }};
    ssl_certificate_key {{ ssl_certificate_key }};
    
    # Security Headers
    add_header Strict-Transport-Security "max-age={{ hsts_max_age }}" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    
    # Main access log
    access_log /var/log/nginx/{{ domain }}-access.log main;
    error_log /var/log/nginx/{{ domain }}-error.log warn;
    
{% for app in apps_with_routes %}
{% for route in app.routes %}
{% if route.type == 'path' %}
    # Path routing: {{ route.path }}
    # Application: {{ app.name }}
    location {{ route.path }} {
{% if route.strip_path is defined and route.strip_path %}
        # Strip path prefix before proxying
        # Handle exact path match (e.g., /agents -> /)
        rewrite ^{{ route.path }}$ / break;
        # Handle subpaths (e.g., /agents/foo -> /foo)
        rewrite ^{{ route.path }}(/.*)$ $1 break;
{% endif %}
        
        proxy_pass http://{{ app.container_ip }}:{{ app.port }};
        
        # Proxy headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
{% if not (route.strip_path is defined and route.strip_path) %}
        proxy_set_header X-Script-Name {{ route.path }};
{% endif %}
        
{% if route.websocket is defined and route.websocket %}
        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
{% elif route.sse is defined and route.sse %}
        # SSE/Streaming support
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_read_timeout 86400;
        # Prevent nginx and upstream proxies from buffering SSE
        add_header X-Accel-Buffering no always;
{% endif %}
        
        # Buffering
        proxy_buffering off;
        proxy_request_buffering off;
        
        # Timeouts
        proxy_connect_timeout {{ nginx_proxy_timeout }};
        proxy_send_timeout {{ nginx_proxy_timeout }};
{% if route.websocket is defined and route.websocket or route.sse is defined and route.sse %}
        # Extended timeout for streaming connections (set above)
{% else %}
        proxy_read_timeout {{ nginx_proxy_timeout }};
{% endif %}
    }

{% endif %}
{% endfor %}
{% endfor %}

    # Dynamically deployed apps (managed by deploy-api at runtime)
    # Location snippets are written here when apps are deployed via Busibox Portal
    include /etc/nginx/app-locations/*.conf;

    # Health check endpoint (for deploy-api / admin system status)
    location = /health {
        default_type application/json;
        return 200 '{"status":"ok"}';
    }

    # Next.js font files - served at root level by next/font
    # next/font/google doesn't prepend basePath to font URLs,
    # so requests come in as /__nextjs_font/* at the root level.
    # Proxy to Busibox Portal (core-apps container) to serve these files.
    location /__nextjs_font {
        proxy_pass http://{{ core_apps_ip }}:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_valid 200 1y;
    }

    # Redirect root to portal
    location = / {
        return 302 /portal;
    }

    # Catch-all: redirect unmatched paths to /portal/<path>
    # This handles cases like /login -> /portal/login
    location / {
        # Try to match specific path routes first, then redirect to portal
        try_files $uri @redirect_to_portal;
    }
    
    location @redirect_to_portal {
        return 302 /portal$uri$is_args$args;
    }
    
    # Error pages
    error_page 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
        internal;
    }
    
    error_page 404 /404.html;
    location = /404.html {
        root /usr/share/nginx/html;
        internal;
    }
}

