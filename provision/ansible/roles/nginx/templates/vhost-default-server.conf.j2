# Default Server Block - Handles IP address and unknown domain access
# Auto-generated by Ansible - modifications will be overwritten

# HTTP default server - redirect to HTTPS
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    
    server_name _;
    
    access_log /var/log/nginx/default-http-access.log main;
    error_log /var/log/nginx/default-http-error.log warn;
    
    # Redirect to HTTPS
    return 301 https://$host$request_uri;
}

# HTTPS default server - serves placeholder content
server {
    listen 443 ssl http2 default_server;
    listen [::]:443 ssl http2 default_server;
    
    server_name _;
    
    # SSL Configuration (same certs as main domain)
    ssl_certificate {{ ssl_certificate }};
    ssl_certificate_key {{ ssl_certificate_key }};
    
    # Security Headers
    add_header Strict-Transport-Security "max-age={{ hsts_max_age }}" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    
    # Logging
    access_log /var/log/nginx/default-https-access.log main;
    error_log /var/log/nginx/default-https-error.log warn;
    
    # Placeholder root
    root /var/www/placeholder;
    index index.html;
    
    # Path routing for agent-manager (exact match)
    location = /agents {
        try_files /agents.html =404;
    }
    
    # Path routing for doc-intel (exact match)
    location = /docs {
        try_files /docs.html =404;
    }
    
    # Path routing for innovation (exact match)
    location = /innovation {
        try_files /innovation.html =404;
    }
    
    # Root / home - ai-portal
    location / {
        try_files /index.html =404;
    }
    
    # Custom 404 page
    error_page 404 /404.html;
    location = /404.html {
        root /var/www/placeholder;
        internal;
    }
}

