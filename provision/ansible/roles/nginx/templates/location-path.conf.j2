    # Path routing: {{ route.path }}
    # Application: {{ app.name }}
    location {{ route.path }} {
{% if route.strip_path is defined and route.strip_path %}
        # Strip path prefix before proxying
        # Handle exact path match (e.g., /agents -> /)
        rewrite ^{{ route.path }}$ / break;
        # Handle subpaths (e.g., /agents/foo -> /foo)
        rewrite ^{{ route.path }}(/.*)$ $1 break;
{% endif %}
        
        proxy_pass http://{{ app.container_ip }}:{{ app.port }};
        
        # Proxy headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
{% if not (route.strip_path is defined and route.strip_path) %}
        proxy_set_header X-Script-Name {{ route.path }};
{% endif %}
        
{% if route.websocket is defined and route.websocket %}
        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
{% elif route.sse is defined and route.sse %}
        # SSE/Streaming support
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_read_timeout 86400;
        # Prevent nginx and upstream proxies from buffering SSE
        add_header X-Accel-Buffering no always;
{% endif %}
        
        # Buffering
        proxy_buffering off;
        proxy_request_buffering off;
        
        # Timeouts
        proxy_connect_timeout {{ nginx_proxy_timeout }};
        proxy_send_timeout {{ nginx_proxy_timeout }};
{% if route.websocket is defined and route.websocket or route.sse is defined and route.sse %}
        # Extended timeout for streaming connections (set above)
{% else %}
        proxy_read_timeout {{ nginx_proxy_timeout }};
{% endif %}
    }

