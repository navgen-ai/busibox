{
  "available_models": {{ available_models | to_nice_json(indent=2) | indent(2) }},
  "purposes": {{ model_purposes | to_nice_json(indent=2) | indent(2) }},
  "metadata": {
    "deployed_at": "{{ ansible_date_time.iso8601 | default(lookup('pipe', 'date -u +%Y-%m-%dT%H:%M:%SZ')) }}",
