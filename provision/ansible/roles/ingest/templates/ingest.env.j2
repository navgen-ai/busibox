# API Configuration
API_HOST=0.0.0.0
API_PORT=8002
API_RELOAD=false

# Test doc harness
TEST_DOC_REPO_PATH={{ test_docs_target_path | default('/srv/test-docs') }}
TEST_DOC_STATE_PATH={{ test_docs_state_path | default('/srv/ingest/test-docs-state.json') }}

# JWT Authentication (authz-issued access tokens)
AUTHZ_JWKS_URL=http://{{ authz_ip }}:8010/.well-known/jwks.json
AUTHZ_ISSUER=busibox-authz
AUTHZ_AUDIENCE=ingest-api
JWT_ALGORITHMS=RS256

# Redis configuration (runs locally on ingest container)
REDIS_HOST=127.0.0.1
REDIS_PORT={{ redis_port | default('6379') }}
REDIS_STREAM=jobs:ingestion
REDIS_CONSUMER_GROUP=workers

# PostgreSQL configuration (files database)
POSTGRES_HOST={{ postgres_host | default('10.96.200.203') }}
POSTGRES_PORT={{ postgres_port | default('5432') }}
POSTGRES_DB={{ files_db | default('files') }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ secrets.postgresql.password }}

# Milvus configuration
MILVUS_HOST={{ milvus_host | default('10.96.200.204') }}
MILVUS_PORT={{ milvus_port | default('19530') }}
MILVUS_COLLECTION={{ milvus_collection | default('documents') }}

# MinIO configuration
MINIO_ENDPOINT={{ minio_host | default(minio_ip) }}:{{ minio_port | default('9000') }}
MINIO_ACCESS_KEY={{ minio_root_user | default('minioadmin') }}
MINIO_SECRET_KEY={{ minio_root_password | default('minioadminchange') }}
MINIO_SECURE=false
MINIO_BUCKET={{ minio_bucket | default('documents') }}

# liteLLM configuration
LITELLM_BASE_URL={{ litellm_base_url | default('http://' + litellm_host + ':' + (litellm_port | string)) }}
LITELLM_API_KEY={{ secrets.litellm.master_key | default('') }}

# FastEmbed configuration (derived from model_registry.yml)
# Lookup: model_purposes.embedding -> available_models[key].model_name
{% set embedding_model_key = model_purposes.embedding | default('bge-large') %}
{% set embedding_model_config = available_models[embedding_model_key] | default({}) %}
FASTEMBED_MODEL={{ embedding_model_config.model_name | default('BAAI/bge-large-en-v1.5') }}
EMBEDDING_DIMENSION={{ embedding_model_config.dimension | default(1024) }}
EMBEDDING_BATCH_SIZE={{ embedding_batch_size | default('32') }}
# Embedding API URL (runs on same container as ingest)
EMBEDDING_API_URL=http://127.0.0.1:8005

# Processing configuration
CHUNK_SIZE_MIN={{ chunk_size_min | default('400') }}
CHUNK_SIZE_MAX={{ chunk_size_max | default('800') }}
CHUNK_OVERLAP_PCT={{ chunk_overlap_pct | default('0.12') }}

# Timeout configuration (seconds)
TIMEOUT_SMALL={{ timeout_small | default('300') }}
TIMEOUT_MEDIUM={{ timeout_medium | default('600') }}
TIMEOUT_LARGE={{ timeout_large | default('1200') }}

# ColPali configuration (visual embeddings - runs on vllm-lxc)
# Uses production ColPali via vllm_ip when use_production_vllm is true
COLPALI_BASE_URL={{ colpali_base_url | default('http://' + vllm_ip + ':9006/v1') }}
COLPALI_API_KEY={{ colpali_api_key | default('EMPTY') }}
COLPALI_ENABLED={{ colpali_enabled | default('true') }}

# Marker configuration (gold standard for PDF extraction, pdfplumber is fallback)
MARKER_ENABLED={{ marker_enabled | default('true') }}
MARKER_USE_GPU={{ marker_use_gpu | default('true') }}
MARKER_GPU_DEVICE={{ marker_gpu_device | default('cuda') }}
# Remote Marker service URL - if set, calls remote API instead of local Marker
MARKER_SERVICE_URL={{ marker_service_url | default('') }}

# Surya batch sizes - control VRAM usage (40MB per batch item for recognition)
# Default 512 = ~20GB VRAM, set lower to share GPU with other services
# With ColPali+vLLM using ~14GB, set to 128 = ~5GB for Marker
RECOGNITION_BATCH_SIZE={{ recognition_batch_size | default('128') }}
DETECTOR_BATCH_SIZE={{ detector_batch_size | default('32') }}
LAYOUT_BATCH_SIZE={{ layout_batch_size | default('16') }}
# Table recognition - can fail on complex tables, lower batch size helps stability
TABLE_REC_BATCH_SIZE={{ table_rec_batch_size | default('4') }}
# Max boxes per table - reduce if getting tensor shape errors on complex tables
TABLE_REC_MAX_BOXES={{ table_rec_max_boxes | default('100') }}

# Model Registry configuration
MODEL_REGISTRY_PATH={{ model_registry_path | default('/etc/ingest/model_registry.json') }}

# LLM Cleanup configuration (uses LLM to fix text quality issues)
# Fixes smashed words, missing spaces, incorrect line breaks
# Enabled by default for better text quality
LLM_CLEANUP_ENABLED={{ llm_cleanup_enabled | default('true') }}

# Bootstrap client credentials for PVT tests
# ai-portal is the standard OAuth client used by all services
# Uses jwt_secret as the shared secret (same as authz service)
AUTHZ_BOOTSTRAP_CLIENT_ID=ai-portal
AUTHZ_BOOTSTRAP_CLIENT_SECRET={{ secrets.jwt_secret | default(secrets.sso.jwt_secret | default('change-me')) }}
{% if secrets.authz is defined and secrets.authz.admin_token is defined %}
AUTHZ_ADMIN_TOKEN={{ secrets.authz.admin_token }}
{% elif secrets.test_credentials is defined and secrets.test_credentials.authz_admin_token is defined %}
AUTHZ_ADMIN_TOKEN={{ secrets.test_credentials.authz_admin_token }}
{% endif %}

