# {{ app_name }} Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

NODE_ENV=production

# Secrets from vault
{% if secrets is defined and secrets[app_name] is defined %}
{%   for secret_key in app_secrets | default([]) %}
{%     if secrets[app_name][secret_key] is defined %}
{{ secret_key | upper }}="{{ secrets[app_name][secret_key] }}"
{%     endif %}
{%   endfor %}
{% endif %}

# Custom environment variables
{% for key, value in app_env_vars.items() %}
{{ key }}="{{ value }}"
{% endfor %}

