#!/bin/bash
# Signal Phone Number Registration Script
# Generated by Ansible - Do not edit manually
#
# Usage:
#   register-signal register +12025551234
#   register-signal verify +12025551234 123456
#   register-signal status
#
# {{ ansible_managed }}

set -euo pipefail

SIGNAL_CLI_URL="http://localhost:{{ signal_cli_port }}"

usage() {
    echo "Usage: $0 <command> [args]"
    echo ""
    echo "Commands:"
    echo "  register <phone>       Start registration (receive SMS code)"
    echo "  verify <phone> <code>  Verify with SMS code"
    echo "  status                 Check registration status"
    echo "  captcha <phone>        Get CAPTCHA challenge URL"
    echo ""
    echo "Examples:"
    echo "  $0 register +12025551234"
    echo "  $0 verify +12025551234 123456"
    exit 1
}

register() {
    local phone="$1"
    echo "Starting registration for $phone..."
    
    response=$(curl -s -X POST "$SIGNAL_CLI_URL/v1/register/$phone" \
        -H "Content-Type: application/json" \
        -d '{"use_voice": false}')
    
    echo "$response" | jq .
    
    if echo "$response" | grep -q "captcha"; then
        echo ""
        echo "⚠️  CAPTCHA required!"
        echo "1. Visit the URL above in a browser"
        echo "2. Complete the CAPTCHA"
        echo "3. Copy the signalcaptcha:// URL"
        echo "4. Run: $0 captcha $phone <captcha-url>"
    fi
}

verify() {
    local phone="$1"
    local code="$2"
    echo "Verifying $phone with code $code..."
    
    curl -s -X POST "$SIGNAL_CLI_URL/v1/register/$phone/verify/$code" | jq .
    
    echo ""
    echo "Checking registration status..."
    status
}

captcha() {
    local phone="$1"
    local captcha_url="$2"
    echo "Submitting CAPTCHA for $phone..."
    
    curl -s -X POST "$SIGNAL_CLI_URL/v1/register/$phone" \
        -H "Content-Type: application/json" \
        -d "{\"captcha\": \"$captcha_url\", \"use_voice\": false}" | jq .
}

status() {
    echo "Signal CLI API Status:"
    curl -s "$SIGNAL_CLI_URL/v1/about" | jq .
}

# Main
if [[ $# -lt 1 ]]; then
    usage
fi

command="$1"
shift

case "$command" in
    register)
        [[ $# -lt 1 ]] && usage
        register "$1"
        ;;
    verify)
        [[ $# -lt 2 ]] && usage
        verify "$1" "$2"
        ;;
    captcha)
        [[ $# -lt 2 ]] && usage
        captcha "$1" "$2"
        ;;
    status)
        status
        ;;
    *)
        usage
        ;;
esac
