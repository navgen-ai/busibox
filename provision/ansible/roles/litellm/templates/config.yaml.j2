# LiteLLM Configuration
# Auto-generated by Ansible - modifications will be overwritten

model_list:
{% for model in litellm_models %}
  - model_name: {{ model.model_name }}
    litellm_params:
      model: {{ model.litellm_params.model }}
      api_base: {{ model.litellm_params.api_base }}
{% if model.litellm_params.api_key is defined %}
      api_key: {{ model.litellm_params.api_key }}
{% endif %}
{% endfor %}

router_settings:
  routing_strategy: {{ litellm_routing_strategy }}
  allowed_fails: {{ litellm_allowed_fails }}
  num_retries: {{ litellm_num_retries }}
  timeout: {{ litellm_timeout }}
{% if litellm_fallbacks | length > 0 %}
  fallbacks: {{ litellm_fallbacks | to_json }}
{% endif %}

litellm_settings:
  drop_params: {{ litellm_drop_params | lower }}
  add_function_to_prompt: {{ litellm_add_function_to_prompt | lower }}
{% if litellm_detailed_debug %}
  set_verbose: true
{% endif %}

general_settings:
  master_key: "{{ litellm_master_key }}"
  # Allow unauthenticated access to health endpoints for monitoring
  public_routes: ["/health", "/health/readiness", "/health/liveliness"]
{% if litellm_enable_swagger %}
  ui_access_mode: admin_only
{% endif %}
{% if litellm_enable_database %}
  # Database configuration (optional - for logging/analytics)
  database_url: "{{ litellm_database_url }}"
  store_model_in_db: false  # Store models in config, not DB
  database_connection_pool_limit: 10
  database_connection_timeout: 10
  # Disable automatic spend tracking (causes Prisma errors)
  disable_spend_logs: true
{% endif %}

