[Unit]
Description=LiteLLM Proxy Server
Documentation=https://docs.litellm.ai/
After=network.target

[Service]
Type=simple
User={{ litellm_user }}
Group={{ litellm_group }}
WorkingDirectory={{ litellm_home }}

# Environment configuration
EnvironmentFile=/etc/default/litellm

# Service execution
ExecStart={{ litellm_venv_dir }}/bin/litellm \
  --config {{ litellm_config_dir }}/config.yaml \
  --port {{ litellm_port }} \
  --host {{ litellm_host }}{% if litellm_enable_database %} \
  --create_tables{% endif %}

# Restart configuration
Restart={{ 'always' if litellm_restart_on_failure else 'no' }}
RestartSec={{ litellm_restart_sec }}

# Resource limits
{% if litellm_memory_limit is defined %}
MemoryMax={{ litellm_memory_limit }}
{% endif %}
{% if litellm_cpu_limit is defined %}
CPUQuota={{ litellm_cpu_limit }}00%
{% endif %}

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={{ litellm_home }}
ReadOnlyPaths={{ litellm_config_dir }}

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=litellm

[Install]
WantedBy=multi-user.target

