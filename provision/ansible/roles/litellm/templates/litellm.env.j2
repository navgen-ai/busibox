# LiteLLM Environment Configuration
# Auto-generated by Ansible - modifications will be overwritten

# Master Key
LITELLM_MASTER_KEY={{ litellm_master_key }}
# Use a stable salt key so encrypted provider keys remain decryptable across restarts.
LITELLM_SALT_KEY={{ litellm_salt_key | default(litellm_master_key) }}

# Logging
LITELLM_LOG={{ litellm_log_level | upper }}

{% if litellm_enable_database %}
# Database
DATABASE_URL={{ litellm_database_url }}
LITELLM_DATABASE_URL={{ litellm_database_url }}
STORE_MODEL_IN_DB=True
{% endif %}

# API keys (from secrets vault)
{% if secrets.openai is defined and secrets.openai.api_key is defined and secrets.openai.api_key %}
OPENAI_API_KEY={{ secrets.openai.api_key }}
{% endif %}
{% set bedrock_key = secrets.bedrock_api_key | default(secrets.bedrock.api_key | default('')) %}
{% if bedrock_key %}
AWS_BEARER_TOKEN_BEDROCK={{ bedrock_key }}
{% if ':' in bedrock_key %}
AWS_ACCESS_KEY_ID={{ bedrock_key.split(':')[0] }}
AWS_SECRET_ACCESS_KEY={{ bedrock_key.split(':')[1] }}
{% endif %}
{% endif %}
{% set bedrock_region = secrets.bedrock_region | default(secrets.bedrock.region | default('')) %}
{% if bedrock_region %}
AWS_REGION={{ bedrock_region }}
{% endif %}

# Disable telemetry
LITELLM_TELEMETRY=False

