# LiteLLM Environment Configuration
# Auto-generated by Ansible - modifications will be overwritten

# Master Key
LITELLM_MASTER_KEY={{ litellm_master_key }}

# Logging
LITELLM_LOG={{ litellm_log_level | upper }}

{% if litellm_enable_database %}
# Database
DATABASE_URL={{ litellm_database_url }}
LITELLM_DATABASE_URL={{ litellm_database_url }}
{% endif %}

# API keys (from secrets vault)
{% if secrets.openai.api_key is defined %}
OPENAI_API_KEY={{ secrets.openai.api_key }}
{% endif %}
{% if secrets.bedrock_api_key is defined %}
AWS_ACCESS_KEY_ID={{ secrets.bedrock_api_key.split(':')[0] if ':' in secrets.bedrock_api_key else '' }}
AWS_SECRET_ACCESS_KEY={{ secrets.bedrock_api_key.split(':')[1] if ':' in secrets.bedrock_api_key else secrets.bedrock_api_key }}
AWS_REGION={{ secrets.bedrock_region | default('us-east-1') }}
{% endif %}

# Disable telemetry
LITELLM_TELEMETRY=False

