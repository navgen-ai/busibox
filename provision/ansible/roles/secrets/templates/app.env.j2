# Auto-generated by Ansible - DO NOT EDIT MANUALLY
# Application: {{ app.name }}
# Generated: {{ ansible_date_time.iso8601 }}
# 
# This file contains sensitive configuration. Permissions: 0600 (owner read/write only)
# Never commit this file to version control.

#
# Required secrets from vault.yml
#
{% if app.secrets is defined and app.secrets | length > 0 %}
{% for secret_key in app.secrets %}
{% if secrets[app.name] is defined and secrets[app.name][secret_key] is defined %}
{{ secret_key | upper }}="{{ secrets[app.name][secret_key] | replace('"', '\\"') | replace('\n', '\\n') | replace('\r', '') }}"
{% else %}
# WARNING: Secret '{{ secret_key }}' not found in vault.yml for app '{{ app.name }}'
{% endif %}
{% endfor %}
{% else %}
# No required secrets defined for this application
{% endif %}

#
# Optional secrets from vault.yml
#
{% if app.optional_secrets is defined and app.optional_secrets | length > 0 %}
{% for secret_key in app.optional_secrets %}
{% if secrets[app.name] is defined and secrets[app.name][secret_key] is defined and secrets[app.name][secret_key] | length > 0 %}
{{ secret_key | upper }}="{{ secrets[app.name][secret_key] | replace('"', '\\"') | replace('\n', '\\n') | replace('\r', '') }}"
{% else %}
# {{ secret_key | upper }}=  # Optional - not set
{% endif %}
{% endfor %}
{% endif %}

#
# Non-secret environment variables
#
{% if app.env is defined and app.env | length > 0 %}
{% for key, value in app.env.items() %}
{{ key }}="{{ value }}"
{% endfor %}
{% else %}
# No environment variables defined for this application
{% endif %}

#
# Deployment metadata
#
DEPLOY_PATH="{{ app.deploy_path }}"
HEALTH_ENDPOINT="{{ app.health_endpoint }}"
APP_NAME="{{ app.name }}"

