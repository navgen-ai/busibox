# vLLM Environment Configuration (Port {{ vllm_port }})
# Auto-generated by Ansible - modifications will be overwritten

# CUDA Configuration  
CUDA_VISIBLE_DEVICES={{ vllm_cuda_visible_devices }}
# Include venv nvidia libs (populated by install) + system CUDA paths
LD_LIBRARY_PATH={{ vllm_nvidia_lib_path | default('') }}:/usr/local/cuda/targets/x86_64-linux/lib:/usr/lib/x86_64-linux-gnu:/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH}

# HuggingFace Configuration
HF_HOME={{ vllm_cache_dir }}
{% if vllm_hf_token is defined and vllm_hf_token != "" %}
HF_TOKEN={{ vllm_hf_token }}
{% endif %}

# Model Cache (HF_HOME above covers TRANSFORMERS_CACHE)
HF_HUB_CACHE={{ vllm_download_dir }}

# vLLM Configuration
VLLM_WORKER_MULTIPROC_METHOD=spawn
VLLM_CACHE_ROOT={{ vllm_cache_dir }}

# Performance Tuning
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# Logging
VLLM_LOGGING_LEVEL={{ vllm_log_level | upper }}

