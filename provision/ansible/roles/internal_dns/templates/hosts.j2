# /etc/hosts - Managed by Ansible
# DO NOT EDIT MANUALLY - Changes will be overwritten
#
# Busibox Internal DNS Mappings
# Environment: {{ busibox_env }}
# Generated: {{ ansible_date_time.iso8601 }}

# Standard localhost entries
127.0.0.1   localhost
::1         localhost ip6-localhost ip6-loopback
ff02::1     ip6-allnodes
ff02::2     ip6-allrouters

# Container's own hostname
{{ ansible_default_ipv4.address }}  {{ ansible_hostname }} {{ ansible_fqdn }}

# =============================================================================
# Busibox Service DNS Mappings
# =============================================================================
# All services accessible via canonical hostnames regardless of container name
# This enables consistent configuration across dev/staging/production

# Infrastructure Services
{{ postgres_ip }}       postgres pg pg-lxc
{{ redis_host }}        redis
{{ minio_ip }}          minio files files-lxc
{{ milvus_ip }}         milvus milvus-lxc
{{ neo4j_ip }}         neo4j graph neo4j-lxc
{{ proxy_ip }}          nginx proxy proxy-lxc

# Core API Services
{{ authz_ip }}          authz-api authz authz-lxc
{{ data_ip }}         data-api data data-lxc
{{ search_api_ip }}     search-api search
{{ agent_ip }}          agent-api agent agent-lxc

# LLM Services
{{ litellm_ip }}        litellm litellm-lxc
{{ vllm_ip }}           vllm vllm-lxc
# NOTE: Ollama is DEPRECATED - use vLLM instead

# Embedded Services (share container with parent service)
{{ agent_ip }}          docs-api docs
{{ authz_ip }}          deploy-api deploy
{{ data_ip }}         embedding-api embedding

# Bridge Service (dedicated container)
{{ bridge_ip }}         bridge-api bridge bridge-lxc

# Application Services
{{ core_apps_ip }}      busibox-portal
{{ core_apps_ip }}      busibox-agents
{{ user_apps_ip }}      user-apps
{{ custom_services_ip }}   custom-services custom-services-lxc

# =============================================================================
# Environment-Specific Aliases
# =============================================================================
{% if busibox_env == 'staging' %}
# Staging environment - add STAGE- prefixed aliases for clarity
{{ postgres_ip }}       STAGE-pg-lxc
{{ minio_ip }}          STAGE-files-lxc
{{ milvus_ip }}         STAGE-milvus-lxc
{{ proxy_ip }}          STAGE-proxy-lxc
{{ authz_ip }}          STAGE-authz-lxc
{{ data_ip }}         STAGE-data-lxc
{{ agent_ip }}          STAGE-agent-lxc
{{ litellm_ip }}        STAGE-litellm-lxc
{{ bridge_ip }}         STAGE-bridge-lxc
{{ core_apps_ip }}      STAGE-core-apps-lxc
{{ user_apps_ip }}      STAGE-user-apps-lxc
{{ custom_services_ip }}   STAGE-custom-services-lxc
{% endif %}

# =============================================================================
# Proxmox Host (for deploy-api to run make install commands)
# =============================================================================
{% if proxmox_host is defined and proxmox_host %}
{{ proxmox_host }}         proxmox pve hypervisor
{% endif %}

# =============================================================================
# Cross-Environment Access (if needed)
# =============================================================================
{% if busibox_env == 'staging' and use_production_vllm | default(false) %}
# Staging uses production vLLM
{{ network_base_octets_production }}.208  prod-vllm
{% endif %}
