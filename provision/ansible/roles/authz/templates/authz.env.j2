POSTGRES_HOST={{ authz_postgres_host }}
POSTGRES_PORT={{ authz_postgres_port }}
POSTGRES_DB={{ authz_postgres_db }}
POSTGRES_USER={{ authz_postgres_user }}
POSTGRES_PASSWORD={{ authz_postgres_password }}

AUTHZ_ISSUER={{ authz_issuer | default('busibox-authz') }}
AUTHZ_ACCESS_TOKEN_TTL={{ authz_access_token_ttl | default('900') }}

# Signing keys are generated and stored in PostgreSQL. If set, this encrypts stored private keys.
AUTHZ_KEY_ENCRYPTION_PASSPHRASE={{ authz_key_encryption_passphrase | default(secrets.jwt_secret) }}

# Signing algorithm (RS256 for broad compatibility)
AUTHZ_SIGNING_ALG={{ authz_signing_alg | default('RS256') }}
AUTHZ_RSA_KEY_SIZE={{ authz_rsa_key_size | default('2048') }}

# Bootstrap OAuth client (ai-portal) so the token exchange flow works immediately.
AUTHZ_BOOTSTRAP_ALLOWED_AUDIENCES={{ authz_bootstrap_allowed_audiences | default('data-api,search-api,agent-api') }}
AUTHZ_BOOTSTRAP_ALLOWED_SCOPES={{ authz_bootstrap_allowed_scopes | default('') }}

# Note: Admin token has been deprecated. Use OAuth client credentials instead.
# Authentication is now handled via the bootstrap client (ai-portal) credentials.

# Master key for envelope encryption (encrypts KEKs stored in PostgreSQL)
# CRITICAL: This key protects all encrypted files
{% if secrets.authz_master_key is defined %}
AUTHZ_MASTER_KEY={{ secrets.authz_master_key }}
{% endif %}

# Admin emails (comma-separated list) - these users are auto-created with Admin role
{% if secrets.admin_email is defined %}
ADMIN_EMAILS={{ secrets.admin_email }}
{% endif %}

# Allowed email domains (comma-separated list) - only emails from these domains can register
{% if secrets.allowed_email_domains is defined %}
ALLOWED_EMAIL_DOMAINS={{ secrets.allowed_email_domains }}
{% endif %}





