# Bridge Service Environment Configuration
# Generated by Ansible - Do not edit manually
# {{ ansible_managed }}

# Application
APP_NAME=bridge
ENVIRONMENT={{ busibox_env }}
DEBUG={{ bridge_debug | lower }}
LOG_LEVEL={{ bridge_log_level }}

# HTTP API Server
BRIDGE_API_PORT={{ bridge_api_port }}

# Signal Channel
SIGNAL_ENABLED={{ (signal_bot_phone_number | length > 0) | lower }}
SIGNAL_CLI_URL=http://localhost:{{ signal_cli_port }}
SIGNAL_PHONE_NUMBER={{ signal_bot_phone_number }}
ALLOWED_PHONE_NUMBERS={% if signal_bot_allowed_numbers %}{{ signal_bot_allowed_numbers | join(',') }}{% endif %}

# Telegram Channel
TELEGRAM_ENABLED={{ bridge_telegram_enabled | default(false) | lower }}
TELEGRAM_BOT_TOKEN={{ bridge_telegram_bot_token | default('') }}
TELEGRAM_POLL_INTERVAL={{ bridge_telegram_poll_interval | default(1.0) }}
TELEGRAM_POLL_TIMEOUT={{ bridge_telegram_poll_timeout | default(25) }}
TELEGRAM_ALLOWED_CHAT_IDS={{ bridge_telegram_allowed_chat_ids | default([]) | join(',') }}

# Discord Channel
DISCORD_ENABLED={{ bridge_discord_enabled | default(false) | lower }}
DISCORD_BOT_TOKEN={{ bridge_discord_bot_token | default('') }}
DISCORD_POLL_INTERVAL={{ bridge_discord_poll_interval | default(2.0) }}
DISCORD_CHANNEL_IDS={{ bridge_discord_channel_ids | default([]) | join(',') }}

# WhatsApp Channel (Cloud API webhook mode)
WHATSAPP_ENABLED={{ bridge_whatsapp_enabled | default(false) | lower }}
WHATSAPP_VERIFY_TOKEN={{ bridge_whatsapp_verify_token | default('') }}
WHATSAPP_ACCESS_TOKEN={{ bridge_whatsapp_access_token | default('') }}
WHATSAPP_PHONE_NUMBER_ID={{ bridge_whatsapp_phone_number_id | default('') }}
WHATSAPP_API_VERSION={{ bridge_whatsapp_api_version | default('v22.0') }}
WHATSAPP_ALLOWED_PHONE_NUMBERS={{ bridge_whatsapp_allowed_phone_numbers | default([]) | join(',') }}

# Cross-channel user bindings
CHANNEL_USER_BINDINGS={{ bridge_channel_user_bindings | default('{}') }}

# Agent API
AGENT_API_URL=http://{{ agent_api_host }}:{{ agent_api_port }}
DATA_API_URL=http://{{ data_ip }}:8002
DEFAULT_AGENT_ID={{ bridge_default_agent_id | default('') }}

# Authentication (Zero Trust)
AUTHZ_BASE_URL=http://{{ authz_ip }}:8010
AUTH_TOKEN_URL=http://{{ authz_ip }}:8010/oauth/token
DELEGATION_TOKEN={{ bridge_delegation_token }}
# Config API (dynamic email config lookup)
CONFIG_API_URL=http://{{ config_host | default(authz_ip) }}:{{ config_api_port | default(8012) }}

# Bot Behavior (Signal-specific)
ENABLE_WEB_SEARCH={{ signal_bot_enable_web_search | lower }}
ENABLE_DOC_SEARCH={{ signal_bot_enable_doc_search | lower }}
DEFAULT_MODEL={{ signal_bot_default_model }}
MAX_MESSAGE_LENGTH={{ signal_bot_max_message_length }}

# Rate Limiting
RATE_LIMIT_MESSAGES={{ signal_bot_rate_limit_messages }}
RATE_LIMIT_WINDOW={{ signal_bot_rate_limit_window }}

# Polling
POLL_INTERVAL={{ signal_bot_poll_interval }}

# Email Channel
EMAIL_ENABLED={{ bridge_email_enabled | lower }}
SMTP_HOST={{ bridge_smtp_host }}
SMTP_PORT={{ bridge_smtp_port }}
SMTP_USER={{ bridge_smtp_user }}
SMTP_PASSWORD={{ bridge_smtp_password }}
SMTP_SECURE={{ bridge_smtp_secure | lower }}
EMAIL_FROM={{ bridge_email_from }}
RESEND_API_KEY={{ bridge_resend_api_key }}

# Inbound email (IMAP polling)
EMAIL_INBOUND_ENABLED={{ bridge_email_inbound_enabled | default(false) | lower }}
IMAP_HOST={{ bridge_imap_host | default('') }}
IMAP_PORT={{ bridge_imap_port | default(993) }}
IMAP_USER={{ bridge_imap_user | default('') }}
IMAP_PASSWORD={{ bridge_imap_password | default('') }}
IMAP_USE_SSL={{ bridge_imap_use_ssl | default(true) | lower }}
IMAP_FOLDER={{ bridge_imap_folder | default('INBOX') }}
EMAIL_INBOUND_POLL_INTERVAL={{ bridge_email_inbound_poll_interval | default(30) }}
EMAIL_ALLOWED_SENDERS={{ bridge_email_allowed_senders | default([]) | join(',') }}

# Future channel configurations (placeholders)
# WHATSAPP_ENABLED=false
# WEBHOOK_ENABLED=false
