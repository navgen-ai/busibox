# Bridge Service Environment Configuration
# Generated by Ansible - Do not edit manually
# {{ ansible_managed }}

# Application
APP_NAME=bridge
ENVIRONMENT={{ busibox_env }}
DEBUG={{ bridge_debug | lower }}
LOG_LEVEL={{ bridge_log_level }}

# Signal CLI REST API (Signal channel)
SIGNAL_CLI_URL=http://localhost:{{ signal_cli_port }}
SIGNAL_PHONE_NUMBER={{ signal_bot_phone_number }}

# Agent API
AGENT_API_URL=http://{{ agent_api_host }}:{{ agent_api_port }}

# Authentication (Zero Trust)
# Uses delegation token for service account - no client_id/secret needed
AUTH_TOKEN_URL=http://{{ authz_ip }}:8010/oauth/token
DELEGATION_TOKEN={{ bridge_delegation_token }}

# Bot Behavior (Signal-specific for now)
ENABLE_WEB_SEARCH={{ signal_bot_enable_web_search | lower }}
ENABLE_DOC_SEARCH={{ signal_bot_enable_doc_search | lower }}
DEFAULT_MODEL={{ signal_bot_default_model }}
MAX_MESSAGE_LENGTH={{ signal_bot_max_message_length }}

# Rate Limiting
RATE_LIMIT_MESSAGES={{ signal_bot_rate_limit_messages }}
RATE_LIMIT_WINDOW={{ signal_bot_rate_limit_window }}

# Polling
POLL_INTERVAL={{ signal_bot_poll_interval }}

# Allowed Phone Numbers (comma-separated, empty = all)
{% if signal_bot_allowed_numbers %}
ALLOWED_PHONE_NUMBERS={{ signal_bot_allowed_numbers | join(',') }}
{% else %}
ALLOWED_PHONE_NUMBERS=
{% endif %}

# Future channel configurations (placeholders)
# EMAIL_ENABLED=false
# WHATSAPP_ENABLED=false
# WEBHOOK_ENABLED=false
