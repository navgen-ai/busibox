# Search API Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Service
SERVICE_NAME=search-api
SERVICE_PORT={{ search_api_port }}
LOG_LEVEL=INFO

# JWT Authentication (authz-issued access tokens)
AUTHZ_JWKS_URL=http://{{ authz_ip }}:8010/.well-known/jwks.json
AUTHZ_ISSUER=busibox-authz
AUTHZ_AUDIENCE=search-api
JWT_ALGORITHMS=RS256

# Milvus
MILVUS_HOST={{ milvus_host }}
MILVUS_PORT={{ milvus_port }}
MILVUS_COLLECTION=documents

# Neo4j graph database (for graph-enhanced search)
NEO4J_URI=bolt://{{ neo4j_host | default(neo4j_ip) }}:{{ neo4j_bolt_port | default('7687') }}
NEO4J_USER={{ neo4j_user | default('neo4j') }}
NEO4J_PASSWORD={{ busibox_secrets.NEO4J_PASSWORD | default('') }}

# PostgreSQL (connect to files database where data_files table exists)
# Database is always "files" - test and prod use different PostgreSQL servers
POSTGRES_HOST={{ postgres_host }}
POSTGRES_PORT={{ postgres_port }}
POSTGRES_DB={{ files_db | default('data') }}
POSTGRES_USER={{ files_user | default(postgres_user) }}
POSTGRES_PASSWORD={{ busibox_secrets.POSTGRES_PASSWORD }}

# Redis (optional caching)
{% if enable_caching and redis_host %}
REDIS_HOST={{ redis_host }}
REDIS_PORT={{ redis_port }}
{% if redis_password is defined %}
REDIS_PASSWORD={{ redis_password }}
{% endif %}
ENABLE_CACHING=true
CACHE_TTL=300
{% else %}
ENABLE_CACHING=false
{% endif %}

# Embedding Service (local FastEmbed on data-lxc)
# Config derived from model_registry.yml
{% set embedding_model_key = (default_purposes | default({}) | combine(model_purposes | default({}))).embedding | default('nomic-embed') %}
{% set embedding_model_config = available_models[embedding_model_key] | default({}) %}
EMBEDDING_API_URL={{ embedding_service_url }}
EMBEDDING_MODEL={{ embedding_model_config.model_name | default('nomic-ai/nomic-embed-text-v1.5') }}
EMBEDDING_DIMENSION={{ embedding_model_config.dimension | default(768) }}

# LiteLLM (for LLM calls)
LITELLM_BASE_URL={{ litellm_base_url | default('http://' + litellm_host + ':' + (litellm_port | string)) }}
LITELLM_API_KEY={{ busibox_secrets.LITELLM_MASTER_KEY | default('') }}

# Reranking configuration
RERANKER_MODEL={{ reranker_model }}
RERANKER_DEVICE={{ reranker_device }}
ENABLE_RERANKING={{ enable_reranking | lower }}
# Reranking mode derived from model_registry reranking purpose.
# Maps provider to mode: "vllm" → "vllm", "local" → "local", else "none".
{% set reranking_model_key = (default_purposes | default({}) | combine(model_purposes | default({}))).reranking | default('') %}
{% set reranking_model_config = available_models[reranking_model_key] | default({}) %}
{% set reranking_provider = reranking_model_config.provider | default('none') %}
{% if enable_reranking and reranking_provider in ['vllm', 'local'] %}
RERANKING_MODE={{ reranking_provider }}
{% else %}
RERANKING_MODE=none
{% endif %}

# vLLM Reranker (for hybrid search via MilvusSearchService)
VLLM_RERANKER_URL=http://{{ hostvars[groups['vllm'][0]]['ansible_host'] if 'vllm' in groups else '10.96.200.208' }}:8002/v1
VLLM_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# Search Defaults
DEFAULT_SEARCH_LIMIT={{ default_search_limit }}
DEFAULT_RERANK_K={{ default_rerank_k }}
MAX_SEARCH_LIMIT={{ max_search_limit }}

# Highlighting
HIGHLIGHT_FRAGMENT_SIZE=200
HIGHLIGHT_NUM_FRAGMENTS=3
HIGHLIGHT_PRE_TAG="<mark>"
HIGHLIGHT_POST_TAG="</mark>"

# Performance
ENABLE_QUERY_CACHE=true
QUERY_CACHE_TTL=300
MAX_CONCURRENT_SEARCHES=50

# AuthZ Token URL (for token exchange)
AUTHZ_TOKEN_URL=http://{{ authz_ip }}:8010/oauth/token

# Test user ID for PVT tests (used in token exchange to get tokens with real user identity)
# This is required for search PVT since it needs to do token exchange when calling ingest
TEST_USER_ID={{ test_user_id | default('00000000-0000-0000-0000-000000000001') }}

