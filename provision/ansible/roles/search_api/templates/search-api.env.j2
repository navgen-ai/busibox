# Search API Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Service
SERVICE_NAME=search-api
SERVICE_PORT={{ search_api_port }}
LOG_LEVEL=INFO

# JWT Authentication (from AI Portal)
# Uses SSO_JWT_SECRET to validate JWT tokens from ai-portal
SSO_JWT_SECRET={{ secrets.jwt_secret }}
JWT_ISSUER=ai-portal
JWT_AUDIENCE=search-api

# Milvus
MILVUS_HOST={{ milvus_host }}
MILVUS_PORT={{ milvus_port }}
MILVUS_COLLECTION=documents

# PostgreSQL (connect to files database where ingestion_files table exists)
POSTGRES_HOST={{ postgres_host }}
POSTGRES_PORT={{ postgres_port }}
POSTGRES_DB={{ files_db | default('files') }}
POSTGRES_USER={{ files_user | default(postgres_user) }}
POSTGRES_PASSWORD={{ files_password | default(postgres_password) }}

# Redis (optional caching)
{% if enable_caching and redis_host %}
REDIS_HOST={{ redis_host }}
REDIS_PORT={{ redis_port }}
{% if redis_password is defined %}
REDIS_PASSWORD={{ redis_password }}
{% endif %}
ENABLE_CACHING=true
CACHE_TTL=300
{% else %}
ENABLE_CACHING=false
{% endif %}

# Embedding Service (local FastEmbed on ingest-lxc)
EMBEDDING_SERVICE_URL={{ embedding_service_url }}
EMBEDDING_MODEL={{ embedding_model }}
EMBEDDING_DIM=1024

# LiteLLM (for LLM calls)
LITELLM_BASE_URL={{ litellm_base_url | default('http://' + litellm_host + ':' + (litellm_port | string)) }}
LITELLM_API_KEY={{ secrets.litellm.master_key | default('') }}

# Reranking (local model for RerankingService)
RERANKER_MODEL={{ reranker_model }}
RERANKER_DEVICE={{ reranker_device }}
ENABLE_RERANKING={{ enable_reranking | lower }}

# vLLM Reranker (for hybrid search via MilvusSearchService)
VLLM_RERANKER_URL=http://{{ hostvars[groups['vllm'][0]]['ansible_host'] if 'vllm' in groups else '10.96.200.208' }}:8002/v1
VLLM_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# Search Defaults
DEFAULT_SEARCH_LIMIT={{ default_search_limit }}
DEFAULT_RERANK_K={{ default_rerank_k }}
MAX_SEARCH_LIMIT={{ max_search_limit }}

# Highlighting
HIGHLIGHT_FRAGMENT_SIZE=200
HIGHLIGHT_NUM_FRAGMENTS=3
HIGHLIGHT_PRE_TAG="<mark>"
HIGHLIGHT_POST_TAG="</mark>"

# Performance
ENABLE_QUERY_CACHE=true
QUERY_CACHE_TTL=300
MAX_CONCURRENT_SEARCHES=50

