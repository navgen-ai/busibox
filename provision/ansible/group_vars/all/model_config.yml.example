# DO NOT EDIT MANUALLY - your changes will be overwritten
# DO NOT COMMIT - this file is machine-specific (.gitignored)
#
# Structure:
#   models:
#     <model_name>:
#       # Technical details (from update-model-config.sh)
#       params_billions: <number>
#       precision: fp16|fp32|bf16|int8|int4
#       quantization: none|gptq|awq|bitsandbytes|gguf
#       gpu_size_gb: <number>
#       disk_size_gb: <number>
#       notes: <string>
#       
#       # GPU/Port assignment (from configure-vllm-model-routing.sh)
#       gpu: <gpu_id> or <gpu_id,gpu_id> for tensor parallelism
#       port: <port_number>
#       tensor_parallel: <number>
#       assigned: true|false
#

