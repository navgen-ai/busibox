#!/usr/bin/env bash
#
# Staging Environment Variables for Busibox Infrastructure
#
# This file defines STAGING instances with IDs offset by +100 and STAGE- prefix
# to allow safe staging/testing without affecting production infrastructure.
#
# Usage:
#   source stage-vars.env  # Load staging configuration
#   bash create_lxc_base.sh staging  # Create staging containers
#   bash destroy_staging.sh  # Clean up staging containers

# Network Configuration (same as production)
BRIDGE=vmbr0
GW=10.96.200.1
CIDR=/21

# Container Configuration
MEM_MB=16384
CPUS=2
DISK_GB=20

# Storage for rootfs
# IMPORTANT: Update this to match your Proxmox storage!
# Run 'pvesm status' on your Proxmox host to see available storage
# Common values: local, local-lvm, local-zfs, dir
# Or run: bash provision/pct/check-storage.sh
STORAGE=local-zfs

# LXC Template
# Check available templates: bash provision/pct/list-templates.sh
# Download: pveam download local <template-name>
# Ubuntu: ubuntu-22.04-standard_22.04-1_amd64.tar.zst
# Debian: debian-12-standard_12.12-1_amd64.tar.zst
TEMPLATE=local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst

# SSH Public Key for Access
SSH_PUBKEY_PATH=/root/.ssh/id_rsa.pub

# ============================================================================
# STAGING Container Definitions (Production ID + 100, STAGE- prefix)
# ============================================================================

# Production: proxy-lxc (200) -> Staging: STAGE-proxy-lxc (300)
CT_PROXY_STAGING=300
IP_PROXY_STAGING=10.96.201.200

# Production: core-apps-lxc (201) -> Staging: STAGE-core-apps-lxc (301)
CT_CORE_APPS_STAGING=301
IP_CORE_APPS_STAGING=10.96.201.201

# Production: agent-lxc (202) -> Staging: STAGE-agent-lxc (302)
CT_AGENT_STAGING=302
IP_AGENT_STAGING=10.96.201.202

# Production: user-apps-lxc (212) -> Staging: STAGE-user-apps-lxc (312)
CT_USER_APPS_STAGING=312
IP_USER_APPS_STAGING=10.96.201.212

# Production: pg-lxc (203) -> Staging: STAGE-pg-lxc (303)
CT_PG_STAGING=303
IP_PG_STAGING=10.96.201.203

# Production: milvus-lxc (204) -> Staging: STAGE-milvus-lxc (304)
CT_MILVUS_STAGING=304
IP_MILVUS_STAGING=10.96.201.204

# Production: files-lxc (205) -> Staging: STAGE-files-lxc (305)
CT_FILES_STAGING=305
IP_FILES_STAGING=10.96.201.205

# Production: data-lxc (206) -> Staging: STAGE-data-lxc (306)
CT_DATA_STAGING=306
IP_DATA_STAGING=10.96.201.206

# Production: litellm-lxc (207) -> Staging: STAGE-litellm-lxc (307)
CT_LITELLM_STAGING=307
IP_LITELLM_STAGING=10.96.201.207

# Production: vllm-lxc (208) -> Staging: STAGE-vllm-lxc (308)
CT_VLLM_STAGING=308
IP_VLLM_STAGING=10.96.201.208

# Production: ollama-lxc (209) -> Staging: STAGE-ollama-lxc (309)
CT_OLLAMA_STAGING=309
IP_OLLAMA_STAGING=10.96.201.209

# Production: authz-lxc (210) -> Staging: STAGE-authz-lxc (310)
CT_AUTHZ_STAGING=310
IP_AUTHZ_STAGING=10.96.201.210

# Production: bridge-lxc (211) -> Staging: STAGE-bridge-lxc (311)
CT_BRIDGE_STAGING=311
IP_BRIDGE_STAGING=10.96.201.211

# ============================================================================
# Staging Mode Indicators
# ============================================================================

# Set to "staging" to use staging configuration
MODE=staging

# Staging environment prefix
STAGE_PREFIX="STAGE-"

# Legacy alias for backward compatibility
TEST_PREFIX="${STAGE_PREFIX}"

# ============================================================================
# Helper Functions
# ============================================================================

print_staging_config() {
  echo "=========================================="
  echo "Busibox STAGING Environment Configuration"
  echo "=========================================="
  echo ""
  echo "Mode: ${MODE}"
  echo "Prefix: ${STAGE_PREFIX}"
  echo ""
  echo "Staging Containers:"
  echo "  STAGE-proxy-lxc:      ${CT_PROXY_STAGING} @ ${IP_PROXY_STAGING}"
  echo "  STAGE-core-apps-lxc:  ${CT_CORE_APPS_STAGING} @ ${IP_CORE_APPS_STAGING}"
  echo "  STAGE-agent-lxc:      ${CT_AGENT_STAGING} @ ${IP_AGENT_STAGING}"
  echo "  STAGE-pg-lxc:         ${CT_PG_STAGING} @ ${IP_PG_STAGING}"
  echo "  STAGE-milvus-lxc:     ${CT_MILVUS_STAGING} @ ${IP_MILVUS_STAGING}"
  echo "  STAGE-files-lxc:      ${CT_FILES_STAGING} @ ${IP_FILES_STAGING}"
  echo "  STAGE-data-lxc:     ${CT_DATA_STAGING} @ ${IP_DATA_STAGING}"
  echo "  STAGE-litellm-lxc:    ${CT_LITELLM_STAGING} @ ${IP_LITELLM_STAGING}"
  echo "  STAGE-vllm-lxc:       ${CT_VLLM_STAGING} @ ${IP_VLLM_STAGING}"
  echo "  STAGE-ollama-lxc:     ${CT_OLLAMA_STAGING} @ ${IP_OLLAMA_STAGING} (optional)"
  echo "  STAGE-bridge-lxc:     ${CT_BRIDGE_STAGING} @ ${IP_BRIDGE_STAGING}"
  echo "  STAGE-user-apps-lxc:  ${CT_USER_APPS_STAGING} @ ${IP_USER_APPS_STAGING}"
  echo ""
  echo "IP Range: 10.96.201.200-212 (STAGING subnet)"
  echo "=========================================="
}

# Legacy alias for backward compatibility
print_test_config() {
  print_staging_config
}

