#!/usr/bin/env bash
# Edit these CTIDs and network to match your host
BRIDGE=vmbr0
CIDR=/21
GW=10.96.200.1

CT_PROXY=200
CT_CORE_APPS=201
CT_AGENT=202
CT_PG=203
CT_MILVUS=204
CT_FILES=205
CT_DATA=206
CT_LITELLM=207
CT_VLLM=208
CT_OLLAMA=209
CT_AUTHZ=210
CT_BRIDGE=211
CT_USER_APPS=212
CT_NEO4J=213
CT_CUSTOM_SERVICES=214

IP_PROXY=10.96.200.200
IP_CORE_APPS=10.96.200.201
IP_AGENT=10.96.200.202
IP_PG=10.96.200.203
IP_MILVUS=10.96.200.204
IP_FILES=10.96.200.205
IP_DATA=10.96.200.206
IP_LITELLM=10.96.200.207
IP_VLLM=10.96.200.208
IP_OLLAMA=10.96.200.209
IP_AUTHZ=10.96.200.210
IP_BRIDGE=10.96.200.211
IP_USER_APPS=10.96.200.212
IP_NEO4J=10.96.200.213
IP_CUSTOM_SERVICES=10.96.200.214

# Debian 12 template on the host (adjust to your template storage/path)
TEMPLATE=local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst

# Storage for rootfs
# Run 'pvesm status' to see available storage on your Proxmox host
# Common values: local, local-lvm, local-zfs, dir
# Or run: bash provision/pct/check-storage.sh
STORAGE=local-zfs

# SSH pubkey to inject for root
SSH_PUBKEY_PATH=/root/.ssh/id_rsa.pub

# CPU/RAM defaults
MEM_MB=16384
CPUS=2
DISK_GB=20
