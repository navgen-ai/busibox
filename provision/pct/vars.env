# Edit these CTIDs and network to match your host
BRIDGE=vmbr0
CIDR=/21
GW=10.96.200.1

CT_OPENWEBUI=201
CT_APPS=202
CT_PG=203
CT_MILVUS=204
CT_FILES=205
CT_INGEST=206
CT_AGENT=207

IP_OPENWEBUI=10.96.200.24
IP_APPS=10.96.200.25
IP_PG=10.96.200.26
IP_MILVUS=10.96.200.27
IP_FILES=10.96.200.28
IP_INGEST=10.96.200.29
IP_AGENT=10.96.200.30

# Debian 12 template on the host (adjust to your template storage/path)
TEMPLATE=local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst

# Storage for rootfs (e.g., local-lvm or zfs pool name)
STORAGE=local-lvm

# SSH pubkey to inject for root
SSH_PUBKEY_PATH=/root/.ssh/id_rsa.pub

# CPU/RAM defaults
MEM_MB=4096
CPUS=2
DISK_GB=20
