#!/usr/bin/env bash
#
# Test Environment Variables for Busibox Infrastructure
#
# This file defines TEST instances with IDs offset by +100 and TEST- prefix
# to allow safe testing without affecting production infrastructure.
#
# Usage:
#   source test-vars.env  # Load test configuration
#   bash create_lxc_base.sh test  # Create test containers
#   bash destroy_test.sh  # Clean up test containers

# Network Configuration (same as production)
BRIDGE=vmbr0
GW=10.96.200.1
CIDR=/21

# Container Configuration
MEM_MB=2048
CPUS=2
DISK_GB=8

# Storage for rootfs
# IMPORTANT: Update this to match your Proxmox storage!
# Run 'pvesm status' on your Proxmox host to see available storage
# Common values: local, local-lvm, local-zfs, dir
# Or run: bash provision/pct/check-storage.sh
STORAGE=local-zfs

# LXC Template
# Check available templates: bash provision/pct/list-templates.sh
# Download: pveam download local <template-name>
# Ubuntu: ubuntu-22.04-standard_22.04-1_amd64.tar.zst
# Debian: debian-12-standard_12.7-1_amd64.tar.zst
TEMPLATE=local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst

# SSH Public Key for Access
SSH_PUBKEY_PATH=/root/.ssh/id_rsa.pub

# ============================================================================
# TEST Container Definitions (Production ID + 100, TEST- prefix)
# ============================================================================

# Production: openwebui-lxc (201) -> Test: TEST-openwebui-lxc (301)
CT_OPENWEBUI_TEST=301
IP_OPENWEBUI_TEST=10.96.201.24

# Production: apps-lxc (202) -> Test: TEST-apps-lxc (302)
CT_APPS_TEST=302
IP_APPS_TEST=10.96.201.25

# Production: pg-lxc (203) -> Test: TEST-pg-lxc (303)
CT_PG_TEST=303
IP_PG_TEST=10.96.201.26

# Production: milvus-lxc (204) -> Test: TEST-milvus-lxc (304)
CT_MILVUS_TEST=304
IP_MILVUS_TEST=10.96.201.27

# Production: files-lxc (205) -> Test: TEST-files-lxc (305)
CT_FILES_TEST=305
IP_FILES_TEST=10.96.201.28

# Production: ingest-lxc (206) -> Test: TEST-ingest-lxc (306)
CT_INGEST_TEST=306
IP_INGEST_TEST=10.96.201.29

# Production: agent-lxc (207) -> Test: TEST-agent-lxc (307)
CT_AGENT_TEST=307
IP_AGENT_TEST=10.96.201.30

# ============================================================================
# Test Mode Indicators
# ============================================================================

# Set to "test" to use test configuration
MODE=test

# Test environment prefix
TEST_PREFIX="TEST-"

# ============================================================================
# Helper Functions
# ============================================================================

print_test_config() {
  echo "=========================================="
  echo "Busibox TEST Environment Configuration"
  echo "=========================================="
  echo ""
  echo "Mode: ${MODE}"
  echo "Prefix: ${TEST_PREFIX}"
  echo ""
  echo "Test Containers:"
  echo "  TEST-openwebui-lxc: ${CT_OPENWEBUI_TEST} @ ${IP_OPENWEBUI_TEST}"
  echo "  TEST-apps-lxc:      ${CT_APPS_TEST} @ ${IP_APPS_TEST}"
  echo "  TEST-pg-lxc:        ${CT_PG_TEST} @ ${IP_PG_TEST}"
  echo "  TEST-milvus-lxc:    ${CT_MILVUS_TEST} @ ${IP_MILVUS_TEST}"
  echo "  TEST-files-lxc:     ${CT_FILES_TEST} @ ${IP_FILES_TEST}"
  echo "  TEST-ingest-lxc:    ${CT_INGEST_TEST} @ ${IP_INGEST_TEST}"
  echo "  TEST-agent-lxc:     ${CT_AGENT_TEST} @ ${IP_AGENT_TEST}"
  echo ""
  echo "IP Range: 10.96.201.24-30 (TEST subnet)"
  echo "=========================================="
}

