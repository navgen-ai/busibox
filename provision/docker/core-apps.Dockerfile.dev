# =============================================================================
# Core Apps - Development Dockerfile
# =============================================================================
#
# Runs both ai-portal and agent-manager in a single container for development.
# This mirrors the Proxmox pattern where core-apps-lxc hosts multiple Next.js apps.
#
# Features:
#   - Volume-mounted source code for both apps
#   - npm-linked busibox-app for live editing
#   - Turbopack hot-reload for both apps
#   - Uses concurrently to run both apps
#
# Usage (via docker-compose.local-dev.yml):
#   docker compose -f docker-compose.yml -f docker-compose.local-dev.yml up
#
# =============================================================================

# Use full Node image instead of Alpine for better compatibility with
# Next.js Turbopack and native modules
FROM node:20-bookworm-slim

# Set working directory
WORKDIR /srv

# Install dependencies for node-gyp, development tools, and nginx
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ curl bash \
    nginx openssl \
    && rm -rf /var/lib/apt/lists/*

# Install concurrently globally for running multiple processes
RUN npm install -g concurrently

# Create directories for apps and nginx
RUN mkdir -p /srv/ai-portal /srv/agent-manager \
    /etc/nginx/ssl \
    /etc/nginx/sites-available \
    /etc/nginx/sites-enabled \
    /etc/nginx/conf.d/apps \
    /run/nginx \
    /var/log/nginx

# Set up npm authentication for private GitHub packages
ARG GITHUB_AUTH_TOKEN
RUN if [ -n "$GITHUB_AUTH_TOKEN" ]; then \
        echo "Setting up npm authentication for @jazzmind packages..." && \
        echo "//npm.pkg.github.com/:_authToken=${GITHUB_AUTH_TOKEN}" > /root/.npmrc && \
        echo "@jazzmind:registry=https://npm.pkg.github.com" >> /root/.npmrc; \
    else \
        echo "WARNING: GITHUB_AUTH_TOKEN not set - npm install may fail for @jazzmind packages"; \
    fi

# Copy nginx configuration for bundled mode (nginx in same container as apps)
# In dev mode, this can be overridden via volume mount
COPY config/nginx-bundled.conf /etc/nginx/nginx.conf

# Copy entrypoint script
COPY provision/docker/core-apps-entrypoint.sh /usr/local/bin/core-apps-entrypoint.sh
RUN chmod +x /usr/local/bin/core-apps-entrypoint.sh

# Expose ports - nginx (80, 443) + apps (3000, 3001)
EXPOSE 80 443 3000 3001

# Environment
ENV NODE_ENV=development
ENV HOSTNAME=0.0.0.0

# Health check - only check nginx (instant, no Next.js compilation)
# Do NOT check /api/health on ports 3000/3001 — in dev mode those trigger
# Turbopack compilation and cause CPU spikes every 30s
HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:80/health || exit 1

# Use entrypoint script to start nginx and both apps
ENTRYPOINT ["/usr/local/bin/core-apps-entrypoint.sh"]
CMD ["dev"]
