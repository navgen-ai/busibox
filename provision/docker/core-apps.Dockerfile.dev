# =============================================================================
# Core Apps - Development Dockerfile
# =============================================================================
#
# Runs all core Next.js apps in a single container for development.
# This mirrors the Proxmox pattern where core-apps-lxc hosts multiple apps.
#
# Features:
#   - Volume-mounted monorepo source code
#   - Per-app dev/prod mode toggling via app-manager.js
#   - Control API on port 9999 for runtime mode switching
#   - Turbopack hot-reload for apps in dev mode
#   - Standalone server for apps in prod mode (lower memory)
#
# Usage (via docker-compose.local-dev.yml):
#   docker compose -f docker-compose.yml -f docker-compose.local-dev.yml up
#
# =============================================================================

# Use full Node image instead of Alpine for better compatibility with
# Next.js Turbopack and native modules
FROM node:20-bookworm-slim

# Set working directory
WORKDIR /srv

# Install dependencies for node-gyp and development tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ curl bash \
    && rm -rf /var/lib/apt/lists/*

# Install workspace package manager
RUN npm install -g pnpm turbo

# Create directories for apps
RUN mkdir -p /srv/busibox-frontend \
    /var/log

# Set up npm authentication for private GitHub packages
ARG GITHUB_AUTH_TOKEN
RUN if [ -n "$GITHUB_AUTH_TOKEN" ]; then \
        echo "Setting up npm authentication for @jazzmind packages..." && \
        echo "//npm.pkg.github.com/:_authToken=${GITHUB_AUTH_TOKEN}" > /root/.npmrc && \
        echo "@jazzmind:registry=https://npm.pkg.github.com" >> /root/.npmrc; \
    else \
        echo "WARNING: GITHUB_AUTH_TOKEN not set - npm install may fail for @jazzmind packages"; \
    fi

# Copy monorepo entrypoint script and process manager
COPY core-apps-entrypoint-monorepo.sh /usr/local/bin/core-apps-entrypoint.sh
COPY app-manager.js /usr/local/bin/app-manager.js
RUN chmod +x /usr/local/bin/core-apps-entrypoint.sh

# Expose app ports + control API port
EXPOSE 3000 3001 3002 3003 3004 3005 3006 9999

# Environment
ENV NODE_ENV=development
ENV HOSTNAME=0.0.0.0

# Health check app port directly.
HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:3000 || exit 1

# Use entrypoint script to start both apps
ENTRYPOINT ["/usr/local/bin/core-apps-entrypoint.sh"]
CMD ["dev"]
