# Agent Server Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=agent-server
ENVIRONMENT=development
DEBUG=false

# ============================================================================
# Model/Provider Configuration
# ============================================================================
# Default model for agents (passed to Pydantic AI)
DEFAULT_MODEL=anthropic:claude-3-5-sonnet

# ============================================================================
# Busibox Service Endpoints
# ============================================================================
# Search API (for RAG document search)
SEARCH_API_URL=http://localhost:8003

# Data API (for document ingestion)
DATA_API_URL=http://localhost:8002

# RAG API (for vector database queries)
RAG_API_URL=http://localhost:8004

# Embedding API (dedicated embedding service - no auth required)
EMBEDDING_API_URL=http://embedding-api:8005

# ============================================================================
# Authentication Configuration
# ============================================================================
# JWT validation (Busibox auth service)
AUTH_ISSUER=https://your-domain.com
AUTH_AUDIENCE=agent-server
AUTH_JWKS_URL=https://your-domain.com/.well-known/jwks.json

# OAuth2 token exchange endpoint
AUTH_TOKEN_URL=http://localhost:8080/oauth/token

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection (async)
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agent

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis for queues/locks (used by APScheduler)
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins (use * for development)
CORS_ORIGINS=*

# ============================================================================
# Skills Configuration (Optional)
# ============================================================================
# Enable AgentSkills-compatible SKILL.md loading
SKILLS_ENABLED=false
# Comma-separated directories scanned recursively for SKILL.md
SKILLS_DIRS=/srv/skills,~/.openclaw/skills,/skills
# Skill cache refresh interval
SKILLS_CACHE_TTL_SECONDS=60
# Optional global RBAC gate (comma-separated roles)
SKILLS_ALLOWED_ROLES=
# Optional ClawHub integration hinting
SKILLS_CLAWHUB_ENABLED=false

# ============================================================================
# Calendar Integration (Optional)
# ============================================================================
# Google OAuth access token with calendar scope.
GOOGLE_CALENDAR_ACCESS_TOKEN=
# Calendar ID (use "primary" for default calendar)
GOOGLE_CALENDAR_ID=primary

# ============================================================================
# OpenTelemetry Configuration (Optional)
# ============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=agent-server
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp

# ============================================================================
# Testing Configuration (Optional - for local tests)
# ============================================================================
# Tests use in-memory SQLite by default, but you can override:
# TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# ============================================================================
# Production Deployment (Busibox)
# ============================================================================
# These are set by Ansible deployment and should NOT be in local .env:
# - MILVUS_HOST
# - MILVUS_PORT
# - MINIO_ENDPOINT
# - POSTGRES_HOST
# - REDIS_HOST
# - TOKEN_SERVICE_URL
# - MASTRA_API_URL
# - LITELLM_BASE_URL
# - LOG_LEVEL
