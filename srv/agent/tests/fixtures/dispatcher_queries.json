      "expected_tools": ["doc_search"],
      "expected_confidence_min": 0.8,
      "reasoning": "Explicitly asks to search internal files"
    },
    {
      "id": "web-002",
      "query": "Find the latest news about artificial intelligence",
      "category": "web_search",
      "available_tools": ["doc_search", "web_search"],
      "enabled_tools": ["doc_search", "web_search"],
      "expected_tools": ["web_search"],
      "expected_confidence_min": 0.8,
      "reasoning": "Latest news requires external web search"
    },
    {
      "id": "disabled-001",
      "query": "What does our Q4 report say?",
