      "enabled_tools": ["web_search"],
      "expected_tools": [],
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.5,
      "reasoning": "doc_search disabled, should not route there"
    },
    {
      "id": "no-tools-001",
      "query": "Help me analyze this data",
      "category": "no_tools_available",
      "available_tools": ["doc_search", "web_search"],
      "enabled_tools": [],
      "expected_tools": [],
      "expected_confidence": 0.0,
      "reasoning": "No tools enabled, should return confidence=0"
    },
    {
      "id": "file-001",
      "query": "Analyze this spreadsheet",
      "category": "file_attachment",
      "available_tools": ["doc_search", "web_search", "file_processor"],
      "enabled_tools": ["doc_search", "web_search", "file_processor"],
      "attachments": [{"name": "data.xlsx", "type": "spreadsheet", "url": "s3://..."}],
      "expected_tools": ["file_processor"],
      "expected_confidence_min": 0.7,
      "reasoning": "File attachment requires file-capable tool"
    },
    {
      "id": "ambiguous-001",
      "query": "Tell me about AI",
