  "accuracy_target": 0.95,
  "confidence_threshold": 0.7,
  "notes": [
    "Test set covers: document search, web search, RAG, ingestion, file attachments, disabled tools, multi-tool, specific agents",
    "Expected accuracy: 95%+ (SC-002)",
    "Confidence < 0.7 should trigger requires_disambiguation=true",
    "Disabled tools should never be selected regardless of query relevance"
