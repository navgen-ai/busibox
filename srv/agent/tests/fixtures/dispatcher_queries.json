      "category": "document_search",
      "available_tools": ["doc_search", "web_search"],
      "enabled_tools": ["doc_search", "web_search"],
      "expected_tools": ["doc_search"],
      "expected_confidence_min": 0.8,
      "reasoning": "Query asks about specific internal document"
    },
    {
      "id": "web-001",
      "query": "What's the weather today in San Francisco?",
      "category": "web_search",
      "available_tools": ["doc_search", "web_search"],
      "enabled_tools": ["doc_search", "web_search"],
      "expected_tools": ["web_search"],
      "expected_confidence_min": 0.8,
      "reasoning": "Query asks for current external information"
    },
    {
      "id": "doc-002",
      "query": "Search our files for information about the merger",
