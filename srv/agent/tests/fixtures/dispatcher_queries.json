      "available_tools": ["doc_search", "web_search"],
      "enabled_tools": ["doc_search", "web_search"],
      "expected_confidence_max": 0.7,
      "reasoning": "Ambiguous query, could be internal docs or web search"
    },
    {
      "id": "rag-001",
      "query": "What are the key themes in our research papers about machine learning?",
      "category": "rag_search",
      "available_tools": ["doc_search", "rag", "web_search"],
      "enabled_tools": ["doc_search", "rag", "web_search"],
      "expected_tools": ["rag"],
      "expected_confidence_min": 0.8,
      "reasoning": "Semantic search across multiple documents best handled by RAG"
    },
    {
      "id": "ingest-001",
      "query": "Process and index this document",
      "category": "document_ingestion",
      "available_tools": ["doc_search", "ingest", "web_search"],
      "enabled_tools": ["doc_search", "ingest", "web_search"],
      "attachments": [{"name": "report.pdf", "type": "pdf", "url": "s3://..."}],
