# =============================================================================
# Busibox Local Development Environment Configuration
# =============================================================================
#
# Copy this file to .env.local and fill in your values:
#   cp env.local.example .env.local
#
# The docker-compose.yml file will automatically load this file.
#
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL credentials (used by all services)
POSTGRES_USER=busibox_user
POSTGRES_PASSWORD=devpassword

# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# LiteLLM master key (for admin access)
LITELLM_MASTER_KEY=sk-local-dev-key

# OpenAI API key (if using OpenAI models)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic API key (if using Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# API key for services to use with LiteLLM
LITELLM_API_KEY=sk-local-dev-key

# AWS Bedrock credentials (if using AWS Bedrock models)
# Option 1: Standard IAM credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION_NAME=us-east-1

# Option 2: Bedrock cross-account access token (base64 encoded ACCESS:SECRET)
# If you have a BEDROCK_API_KEY from production vault, decode it and set above
# BEDROCK_API_KEY=<base64-encoded-token>

# =============================================================================
# AUTHZ CONFIGURATION
# =============================================================================

# Master key for envelope encryption (change this!)
AUTHZ_MASTER_KEY=local-master-key-change-in-production

# Access token TTL in seconds (15 minutes default)
AUTHZ_ACCESS_TOKEN_TTL=900

# =============================================================================
# AI PORTAL CONFIGURATION
# =============================================================================

# AI Portal database connection (for automatic library migration)
# The ingest-api will migrate libraries from AI Portal on startup if configured
# Leave unset to skip migration (libraries created on-demand instead)
AI_PORTAL_DB_HOST=postgres
AI_PORTAL_DB_PORT=5432
AI_PORTAL_DB_NAME=ai_portal
AI_PORTAL_DB_USER=busibox_user
# AI_PORTAL_DB_PASSWORD defaults to POSTGRES_PASSWORD if not set

# Better Auth secret (change this!)
BETTER_AUTH_SECRET=dev-secret-change-in-production

# SSO JWT secret (for app-to-app authentication)
SSO_JWT_SECRET=dev-sso-secret

# Admin email (first user to sign up gets admin access)
ADMIN_EMAIL=admin@localhost

# Allowed email domains (* for any, or comma-separated list)
ALLOWED_EMAIL_DOMAINS=*

# Email provider (leave empty for console logging in dev)
RESEND_API_KEY=
EMAIL_FROM=noreply@localhost

# =============================================================================
# SMTP CONFIGURATION (for agent task notifications)
# =============================================================================

# SMTP server settings (optional - leave blank for console logging in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
# Agent-specific settings (OAuth clients are auto-registered by authz on startup)

# =============================================================================
# EMBEDDING SERVICE
# =============================================================================

# Embedding API URL (dedicated embedding service)
# This service loads the model once and stays running while other services restart
EMBEDDING_API_URL=http://embedding-api:8005

# FastEmbed model - use bge-large for consistency with production
# Override with BAAI/bge-small-en-v1.5 for faster dev (384-d, ~134MB vs 1024-d, ~1.3GB)
FASTEMBED_MODEL=BAAI/bge-large-en-v1.5

# Embedding dimension (must match model)
EMBEDDING_DIMENSION=1024

# Embedding batch size for bulk operations
EMBEDDING_BATCH_SIZE=32

# =============================================================================
# PROCESSING OPTIONS
# =============================================================================

# Marker PDF extraction (set to false if no GPU or to speed up startup)
MARKER_ENABLED=true
MARKER_USE_GPU=false

# ColPali visual embeddings (requires vLLM with ColPali model)
COLPALI_ENABLED=false

# LLM cleanup for extracted text
LLM_CLEANUP_ENABLED=true

# Reranking (uses sentence-transformers model)
ENABLE_RERANKING=true

# =============================================================================
# OPTIONAL: vLLM LOCAL LLM (for Mac Studio or GPU systems)
# =============================================================================

# Uncomment and configure if running local vLLM instance
# VLLM_BASE_URL=http://host.docker.internal:8080/v1
# VLLM_API_KEY=EMPTY

# =============================================================================
# OPTIONAL: GITHUB OAUTH (for deployment management)
# =============================================================================

# GITHUB_CLIENT_ID=your_github_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
# GITHUB_REDIRECT_URI=http://localhost:3000/api/admin/github/callback

# =============================================================================
# GITHUB AUTHENTICATION (REQUIRED for building Next.js apps)
# =============================================================================

# GitHub personal access token with read:packages scope
# REQUIRED: This is needed to install @jazzmind/busibox-app from GitHub Packages
# Get a token from: https://github.com/settings/tokens (classic token with read:packages)
GITHUB_AUTH_TOKEN=ghp_your_github_token

# =============================================================================
# APP DIRECTORIES (for development volume mounts)
# =============================================================================

# Paths to app repositories (auto-detected by install script if not set)
# These are used by docker-compose.local-dev.yml for volume mounts
# AI_PORTAL_DIR=/path/to/ai-portal
# AGENT_MANAGER_DIR=/path/to/agent-manager
# BUSIBOX_APP_DIR=/path/to/busibox-app
# APPS_BASE_DIR=/path/to/parent/directory

# =============================================================================
# DEMO/PRODUCTION MODE (for docker-up ENV=demo)
# =============================================================================

# GitHub ref (branch or tag) to build from in demo/production mode
# Default is 'main', but you can specify a release tag like 'v1.2.3'
AI_PORTAL_GITHUB_REF=main
AGENT_MANAGER_GITHUB_REF=main
