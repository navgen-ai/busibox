# =============================================================================
# Busibox Local Development Environment Configuration
# =============================================================================
#
# Copy this file to .env.local and fill in your values:
#   cp env.local.example .env.local
#
# The docker-compose.local.yml file will automatically load this file.
#
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL credentials (used by all services)
POSTGRES_USER=busibox_user
POSTGRES_PASSWORD=devpassword

# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# LiteLLM master key (for admin access)
LITELLM_MASTER_KEY=sk-local-dev-key

# OpenAI API key (if using OpenAI models)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic API key (if using Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# API key for services to use with LiteLLM
LITELLM_API_KEY=sk-local-dev-key

# AWS Bedrock credentials (if using AWS Bedrock models)
# Option 1: Standard IAM credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION_NAME=us-east-1

# Option 2: Bedrock cross-account access token (base64 encoded ACCESS:SECRET)
# If you have a BEDROCK_API_KEY from production vault, decode it and set above
# BEDROCK_API_KEY=<base64-encoded-token>

# =============================================================================
# AUTHZ CONFIGURATION
# =============================================================================

# Admin token for authz service (internal API access)
AUTHZ_ADMIN_TOKEN=local-admin-token

# Master key for envelope encryption (change this!)
AUTHZ_MASTER_KEY=local-master-key-change-in-production

# Access token TTL in seconds (15 minutes default)
AUTHZ_ACCESS_TOKEN_TTL=900

# Bootstrap OAuth client (ai-portal)
AUTHZ_BOOTSTRAP_CLIENT_ID=ai-portal
AUTHZ_BOOTSTRAP_CLIENT_SECRET=ai-portal-secret

# =============================================================================
# AI PORTAL CONFIGURATION
# =============================================================================

# Better Auth secret (change this!)
BETTER_AUTH_SECRET=dev-secret-change-in-production

# SSO JWT secret (for app-to-app authentication)
SSO_JWT_SECRET=dev-sso-secret

# Admin email (first user to sign up gets admin access)
ADMIN_EMAIL=admin@localhost

# Allowed email domains (* for any, or comma-separated list)
ALLOWED_EMAIL_DOMAINS=*

# Email provider (leave empty for console logging in dev)
RESEND_API_KEY=
EMAIL_FROM=noreply@localhost

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# Agent API OAuth client credentials
AGENT_API_CLIENT_ID=agent-api
AGENT_API_CLIENT_SECRET=agent-api-secret

# Agent Manager OAuth client credentials
AGENT_MANAGER_CLIENT_ID=agent-manager
AGENT_MANAGER_CLIENT_SECRET=agent-manager-secret

# =============================================================================
# PROCESSING OPTIONS
# =============================================================================

# Marker PDF extraction (set to false if no GPU or to speed up startup)
MARKER_ENABLED=true
MARKER_USE_GPU=false

# ColPali visual embeddings (requires vLLM with ColPali model)
COLPALI_ENABLED=false

# LLM cleanup for extracted text
LLM_CLEANUP_ENABLED=true

# Reranking (uses sentence-transformers model)
ENABLE_RERANKING=true

# =============================================================================
# OPTIONAL: vLLM LOCAL LLM (for Mac Studio or GPU systems)
# =============================================================================

# Uncomment and configure if running local vLLM instance
# VLLM_BASE_URL=http://host.docker.internal:8080/v1
# VLLM_API_KEY=EMPTY

# =============================================================================
# OPTIONAL: GITHUB OAUTH (for deployment management)
# =============================================================================

# GITHUB_CLIENT_ID=your_github_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
# GITHUB_REDIRECT_URI=http://localhost:3000/api/admin/github/callback
